@model MotelLeAnh49.Models.Room
@{
    ViewData["Title"] = "Chi tiết phòng";
}

<style>
    .room-detail-section {
        padding: 50px 0;
    }

    .room-gallery {
        margin-bottom: 30px;
    }

    .main-image {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .thumbnail-gallery {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        overflow-x: auto;
    }

    .thumbnail {
        width: 120px;
        height: 80px;
        object-fit: cover;
        border-radius: 5px;
        cursor: pointer;
        transition: .3s;
        border: 3px solid transparent;
    }

        .thumbnail:hover {
            border-color: var(--primary-color);
        }

    .room-info {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .price-box {
        background: linear-gradient(135deg, var(--primary-color), #c09d2e);
        padding: 25px;
        border-radius: 10px;
        color: white;
        text-align: center;
        margin: 30px 0;
    }

    /* Price table */
    .price-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

        .price-table th,
        .price-table td {
            padding: 10px 14px;
            border: 1px solid #e8e0cc;
            font-size: 14px;
        }

        .price-table th {
            background: #fdf6e3;
            font-weight: 600;
            color: #7a5c1a;
            width: 55%;
        }

        .price-table td {
            text-align: right;
            font-weight: 500;
            color: #333;
        }

        .price-table tr:last-child td,
        .price-table tr:last-child th {
            border-bottom: none;
        }

    /* Info badges */
    .info-badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 18px 0;
    }

    .info-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        background: #fdf6e3;
        border: 1px solid #e8d8a0;
        color: #7a5c1a;
    }

        .info-badge i {
            font-size: 15px;
        }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #555;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin: 22px 0 10px;
        padding-bottom: 6px;
        border-bottom: 2px solid #f0e6c0;
    }

    .booking-sidebar {
        position: sticky;
        top: 100px;
    }

    .booking-card {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

        .booking-card .price-summary {
            margin-bottom: 20px;
        }

        .booking-card .price-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            padding: 6px 0;
            border-bottom: 1px dashed #eee;
            color: #555;
        }

            .booking-card .price-row:last-child {
                border-bottom: none;
                font-weight: 700;
                font-size: 15px;
                color: #333;
                margin-top: 4px;
            }

    /* ====== FLOATING CHAT WIDGET ====== */
    #chat-fab {
        position: fixed;
        bottom: 28px;
        right: 28px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #c9a84c;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(201,168,76,.45);
        z-index: 9999;
        transition: transform .2s, background .15s;
    }

        #chat-fab:hover {
            background: #e8c97a;
            transform: scale(1.07);
        }

        #chat-fab svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: #1a1915;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    #chat-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #e74c3c;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    #chat-box {
        position: fixed;
        bottom: 96px;
        right: 28px;
        width: 360px;
        height: 520px;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: #0e0d0b;
        border: .5px solid #3a3930;
        box-shadow: 0 16px 48px rgba(0,0,0,.6);
        z-index: 9998;
        transform: scale(.92) translateY(20px);
        opacity: 0;
        transition: transform .28s cubic-bezier(.34,1.56,.64,1), opacity .2s;
        pointer-events: none;
        font-family: 'DM Mono', 'Courier New', monospace;
    }

        #chat-box.cx-open {
            transform: scale(1) translateY(0);
            opacity: 1;
            pointer-events: all;
        }

    .cx-header {
        padding: 14px 16px;
        background: #1a1915;
        border-bottom: .5px solid #3a3930;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .cx-icon {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #c9a84c;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }

    .cx-title {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 14px;
        color: #f0ead8;
        line-height: 1.2;
    }

    .cx-sub {
        font-size: 10px;
        color: #8a8674;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-top: 2px;
    }

    .cx-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4caf7d;
        margin-left: auto;
        flex-shrink: 0;
    }

    .cx-close-btn {
        margin-left: 8px;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: transparent;
        border: .5px solid #3a3930;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #8a8674;
        font-size: 13px;
        line-height: 1;
        transition: background .15s;
        flex-shrink: 0;
    }

        .cx-close-btn:hover {
            background: #2e2d27;
            color: #f0ead8;
        }

    .cx-msgs {
        flex: 1;
        overflow-y: auto;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        scrollbar-width: thin;
        scrollbar-color: #3a3930 transparent;
    }

        .cx-msgs::-webkit-scrollbar {
            width: 4px;
        }

        .cx-msgs::-webkit-scrollbar-thumb {
            background: #3a3930;
            border-radius: 4px;
        }

    .cx-msg {
        display: flex;
        flex-direction: column;
        max-width: 86%;
    }

        .cx-msg.user {
            align-self: flex-end;
            align-items: flex-end;
        }

        .cx-msg.ai {
            align-self: flex-start;
        }

    .cx-lbl {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #8a8674;
        margin-bottom: 3px;
    }

    .cx-msg.user .cx-lbl {
        color: #a07a2a;
    }

    .cx-bubble {
        padding: 9px 13px;
        border-radius: 12px;
        font-size: 12.5px;
        line-height: 1.6;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .cx-msg.user .cx-bubble {
        background: #2a2615;
        border: .5px solid #c9a84c;
        color: #f0ead8;
        border-bottom-right-radius: 3px;
    }

    .cx-msg.ai .cx-bubble {
        background: #1e1e1a;
        border: .5px solid #3a3930;
        color: #ccc8b8;
        border-bottom-left-radius: 3px;
    }

    .cx-typing-dots {
        display: flex;
        gap: 4px;
        padding: 11px 13px;
        align-items: center;
    }

        .cx-typing-dots span {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: #c9a84c;
            animation: cxBlink 1.2s ease-in-out infinite;
        }

            .cx-typing-dots span:nth-child(2) {
                animation-delay: .2s;
            }

            .cx-typing-dots span:nth-child(3) {
                animation-delay: .4s;
            }

    /* ==================== PHẦN ĐẶT PHÒNG MỚI ==================== */
    .booking-card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        position: sticky;
        top: 100px;
    }

    .date-picker-group {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
    }

    .alert-booked {
        background: #ffe0e0;
        color: #c82333;
        padding: 14px;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
        margin: 15px 0;
    }

    .alert-available {
        background: #d4edda;
        color: #155724;
        padding: 14px;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
        margin: 15px 0;
    }

    .btn-book {
        width: 100%;
        padding: 15px;
        font-size: 18px;
        font-weight: 700;
        border: none;
        border-radius: 8px;
        cursor: pointer;
    }

        .btn-book:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
    @@keyframes cxBlink {
        0%, 80%, 100% {
            opacity: .2
        }

        40% {
            opacity: 1
        }
    }

    .cx-composer {
        border-top: .5px solid #3a3930 !important;
        padding: 12px 14px !important;
        display: flex !important;
        flex-direction: row !important;
        align-items: flex-end !important;
        gap: 8px !important;
        background: #1a1915 !important;
        flex-shrink: 0 !important;
        box-sizing: border-box !important;
    }

        .cx-composer textarea {
            flex: 1 1 auto !important;
            min-width: 0 !important;
            background: #2e2d27 !important;
            border: .5px solid #3a3930 !important;
            border-radius: 10px !important;
            padding: 8px 11px !important;
            font-family: 'DM Mono', 'Courier New', monospace !important;
            font-size: 12.5px !important;
            color: #f0ead8 !important;
            resize: none !important;
            outline: none !important;
            min-height: 38px !important;
            max-height: 110px !important;
            height: 38px !important;
            line-height: 1.5 !important;
            transition: border-color .2s !important;
            box-sizing: border-box !important;
            display: block !important;
        }

            .cx-composer textarea::placeholder {
                color: #8a8674;
            }

            .cx-composer textarea:focus {
                border-color: #c9a84c !important;
                box-shadow: none !important;
            }

    .cx-send-btn {
        width: 36px !important;
        height: 36px !important;
        min-width: 36px !important;
        border-radius: 50% !important;
        background: #c9a84c !important;
        border: none !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        flex-shrink: 0 !important;
        transition: background .15s, transform .1s;
        padding: 0 !important;
    }

        .cx-send-btn:hover {
            background: #e8c97a !important;
        }

        .cx-send-btn:active {
            transform: scale(.93);
        }

        .cx-send-btn:disabled {
            opacity: .45 !important;
            cursor: not-allowed !important;
        }

        .cx-send-btn svg {
            width: 14px !important;
            height: 14px !important;
            fill: none !important;
            stroke: #1a1915 !important;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
</style>

<div class="room-detail-section">
    <div class="container">
        <div class="row">

            <!-- ── Cột trái: ảnh + thông tin ── -->
            <div class="col-lg-8">
                <img id="mainImage"
                     src="@(Model?.RoomImages?.FirstOrDefault()?.ImagePath ?? "https://images.unsplash.com/photo-1611892440504-42a792e24d32?w=1200")"
                     class="main-image" />

                <div class="thumbnail-gallery">
                    @foreach (var img in Model.RoomImages ?? new List<MotelLeAnh49.Models.RoomImage>())
                    {
                        <img src="@img.ImagePath" class="thumbnail"
                             onclick="changeMainImage(this.src)" />
                    }
                </div>

                <div class="room-info mt-3">
                    <h1>Phòng @Model?.RoomNumber</h1>
                    <p class="text-muted mb-0">@Model?.RoomType</p>

                    <!-- Badges thông tin nhanh -->
                    <div class="info-badge-row">
                        <span class="info-badge">
                            👥 Tối đa @Model?.MaxGuests khách
                        </span>
                        @if (Model?.ExtraGuestFee > 0)
                        {
                            <span class="info-badge">
                                ➕ Phụ thu thêm người: @Model.ExtraGuestFee.ToString("N0") đ
                            </span>
                        }
                    </div>

                    <!-- Bảng giá -->
                    <div class="section-title">Bảng giá</div>

                    <div class="price-box">
                        <div style="font-size:13px; opacity:.85; margin-bottom:4px;">Giá qua đêm</div>
                        <div style="font-size:26px; font-weight:700;">@Model?.OvernightPrice.ToString("N0") đ</div>
                    </div>

                    <table class="price-table">
                        <tbody>
                            <tr>
                                <th>🌙 Giá qua đêm</th>
                                <td>@Model?.OvernightPrice.ToString("N0") đ</td>
                            </tr>
                            <tr>
                                <th>☀️ Giá theo ngày</th>
                                <td>@Model?.DayPrice.ToString("N0") đ</td>
                            </tr>
                            <tr>
                                <th>⏱ Giá giờ đầu</th>
                                <td>@Model?.FirstHourPrice.ToString("N0") đ</td>
                            </tr>
                            <tr>
                                <th>⏱ Giá mỗi giờ tiếp theo</th>
                                <td>@Model?.NextHourPrice.ToString("N0") đ</td>
                            </tr>
                            @if (Model?.ExtraGuestFee > 0)
                            {
                                <tr>
                                    <th>👤 Phụ thu thêm người</th>
                                    <td>@Model.ExtraGuestFee.ToString("N0") đ / người</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ── Cột phải: sidebar đặt phòng ── -->
            <div class="col-lg-4">
                <div class="booking-card booking-sidebar">
                    <!-- Phần giá cũ giữ nguyên -->
                    <div class="price-summary">
                        <div class="price-row">
                            <span>🌙 Qua đêm</span>
                            <span>@Model?.OvernightPrice.ToString("N0") đ</span>
                        </div>
                        <div class="price-row">
                            <span>☀️ Theo ngày</span>
                            <span>@Model?.DayPrice.ToString("N0") đ</span>
                        </div>
                        <div class="price-row">
                            <span>⏱ Giờ đầu</span>
                            <span>@Model?.FirstHourPrice.ToString("N0") đ</span>
                        </div>
                        <div class="price-row">
                            <span>⏱ Giờ tiếp</span>
                            <span>@Model?.NextHourPrice.ToString("N0") đ / giờ</span>
                        </div>
                        <div class="price-row">
                            <span>👥 Khách tối đa</span>
                            <span>@Model?.MaxGuests người</span>
                        </div>
                    </div>

                    <hr style="margin: 25px 0;">

                    <!-- PHẦN MỚI: KIỂM TRA TÌNH TRẠNG PHÒNG -->
                    <h5>📅 Kiểm tra tình trạng phòng</h5>
                    <p class="text-muted small">Chọn ngày để xem phòng còn trống không</p>

                    <div class="date-picker-group">
                        <div style="flex:1">
                            <label class="form-label">Check In</label>
                            <input type="date" id="checkInDate" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div style="flex:1">
                            <label class="form-label">Check Out</label>
                            <input type="date" id="checkOutDate" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>

                    <div id="availabilityResult"></div>

                    <!-- NÚT ĐẶT PHÒNG ĐỘNG -->
                    <button id="btnBookNow" class="btn btn-success btn-book w-100 mt-3" style="display: none;">
                        <i class="fas fa-calendar-check"></i> Đặt phòng ngay
                    </button>

                    <button id="btnBookDisabled" class="btn btn-secondary btn-book w-100 mt-3"
                            style="display: none; background:#dc3545; color:white;" disabled>
                        ❌ Phòng đã được đặt trong khoảng thời gian này
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ====== FLOATING CHAT WIDGET ====== -->
<button id="chat-fab" onclick="cxToggle()" title="Chat hỗ trợ">
    <svg viewBox="0 0 24 24">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
    </svg>
    <span id="chat-badge">1</span>
</button>

<div id="chat-box">
    <div class="cx-header">
        <div class="cx-icon">&#9768;</div>
        <div>
            <div class="cx-title">Concierge IA</div>
            <div class="cx-sub">MotelLeAnh49 &middot; 24/7</div>
        </div>
        <div class="cx-dot"></div>
        <button class="cx-close-btn" onclick="cxToggle()" title="Đóng">&#x2715;</button>
    </div>

    <div class="cx-msgs" id="cx-msgs">
        <div class="cx-msg ai">
            <div class="cx-lbl">Concierge IA</div>
            <div class="cx-bubble">Xin chào! Tôi là trợ lý ảo của MotelLeAnh49. Tôi có thể giúp bạn về phòng, giá cả, hoặc đặt phòng!</div>
        </div>
    </div>

    <div class="cx-composer">
        @Html.AntiForgeryToken()
        <textarea id="cx-input" rows="1" placeholder="Hỏi về phòng, giá, dịch vụ…"></textarea>
        <button class="cx-send-btn" id="cx-send-btn" onclick="cxSend()" title="Gửi">
            <svg viewBox="0 0 24 24">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
        </button>
    </div>
</div>

<script>
    function changeMainImage(src) {
        document.getElementById('mainImage').src = src;
    }

    let cxIsOpen = false;

    function cxToggle() {
        cxIsOpen = !cxIsOpen;
        document.getElementById('chat-box').classList.toggle('cx-open', cxIsOpen);
        document.getElementById('chat-badge').style.display = 'none';
        if (cxIsOpen) {
            setTimeout(() => document.getElementById('cx-input').focus(), 300);
        }
    }

    document.getElementById('cx-input').addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 110) + 'px';
    });

    document.getElementById('cx-input').addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            cxSend();
        }
    });

    function cxAddMessage(role, text) {
        const msgs = document.getElementById('cx-msgs');
        const wrapper = document.createElement('div');
        wrapper.className = 'cx-msg ' + role;
        const label = document.createElement('div');
        label.className = 'cx-lbl';
        label.textContent = role === 'user' ? 'Bạn' : 'Concierge IA';
        const bubble = document.createElement('div');
        bubble.className = 'cx-bubble';
        bubble.textContent = text;
        wrapper.appendChild(label);
        wrapper.appendChild(bubble);
        msgs.appendChild(wrapper);
        msgs.scrollTop = msgs.scrollHeight;
    }

    function cxShowTyping() {
        const msgs = document.getElementById('cx-msgs');
        const wrapper = document.createElement('div');
        wrapper.className = 'cx-msg ai';
        wrapper.id = 'cx-typing-indicator';
        const label = document.createElement('div');
        label.className = 'cx-lbl';
        label.textContent = 'Concierge IA';
        const bubble = document.createElement('div');
        bubble.className = 'cx-bubble cx-typing-dots';
        bubble.innerHTML = '<span></span><span></span><span></span>';
        wrapper.appendChild(label);
        wrapper.appendChild(bubble);
        msgs.appendChild(wrapper);
        msgs.scrollTop = msgs.scrollHeight;
    }

    function cxHideTyping() {
        const el = document.getElementById('cx-typing-indicator');
        if (el) el.remove();
    }

    async function cxSend() {
        const input = document.getElementById('cx-input');
        const sendBtn = document.getElementById('cx-send-btn');
        const text = input.value.trim();
        if (!text) return;

        input.value = '';
        input.style.height = 'auto';
        input.disabled = true;
        sendBtn.disabled = true;

        cxAddMessage('user', text);
        cxShowTyping();

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const res = await fetch('/Chat/Send', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ message: text })
            });

            if (!res.ok) throw new Error('Lỗi server: ' + res.status);

            const data = await res.json();
            cxHideTyping();
            cxAddMessage('ai', data.response);

        } catch (err) {
            cxHideTyping();
            cxAddMessage('ai', 'Xin lỗi, đã xảy ra lỗi kết nối. Vui lòng thử lại sau.');
        }

        input.disabled = false;
        sendBtn.disabled = false;
        input.focus();
    }
</script>
<<script>
     const roomId = @Model.Id;

     async function checkAvailability() {
         const checkIn = document.getElementById("checkInDate").value;
         const checkOut = document.getElementById("checkOutDate").value;
         const resultDiv = document.getElementById("availabilityResult");
         const btnBook = document.getElementById("btnBookNow");
         const btnDisabled = document.getElementById("btnBookDisabled");

         // === BAN ĐẦU HOẶC CHƯA CHỌN ĐỦ NGÀY → NÚT BỊ MỜ ===
         if (!checkIn || !checkOut) {
             resultDiv.innerHTML = "";
             btnBook.style.display = "block";
             btnBook.disabled = true;           // nút mờ
             btnDisabled.style.display = "none";
             return;
         }

         try {
             const res = await fetch(`/Bookings/GetBookedRanges?roomId=${roomId}`);
             const bookedRanges = await res.json();

             const isBooked = bookedRanges.some(range => {
                 const rangeIn = new Date(range.checkIn);
                 const rangeOut = new Date(range.checkOut);
                 const selIn = new Date(checkIn);
                 const selOut = new Date(checkOut);
                 return selIn < rangeOut && selOut > rangeIn;
             });

             if (isBooked) {
                 // Trường hợp đã đặt
                 resultDiv.innerHTML = `<div class="alert-booked">❌ Phòng đã được đặt trong khoảng thời gian này</div>`;
                 btnBook.style.display = "block";
                 btnBook.disabled = true;           // nút mờ
                 btnDisabled.style.display = "none";
             } else {
                 // Trường hợp còn trống
                 resultDiv.innerHTML = `<div class="alert-available">✅ Phòng còn trống! Bạn có thể đặt ngay.</div>`;
                 btnBook.style.display = "block";
                 btnBook.disabled = false;          // nút xanh rõ, nhấn được
                 btnDisabled.style.display = "none";
             }
         } catch (e) {
             resultDiv.innerHTML = `<div class="alert-booked">Lỗi kiểm tra phòng. Vui lòng thử lại.</div>`;
             btnBook.style.display = "block";
             btnBook.disabled = true;
             btnDisabled.style.display = "none";
         }
     }

     // Sự kiện thay đổi ngày
     document.getElementById("checkInDate").addEventListener("change", () => {
         const co = document.getElementById("checkOutDate");
         if (co.value && co.value <= document.getElementById("checkInDate").value) co.value = "";
         co.min = document.getElementById("checkInDate").value;
         checkAvailability();
     });

     document.getElementById("checkOutDate").addEventListener("change", checkAvailability);

     // Click nút Đặt phòng (chỉ hoạt động khi nút không bị disable)
     document.getElementById("btnBookNow").addEventListener("click", () => {
         if (document.getElementById("btnBookNow").disabled) return;

         const ci = document.getElementById("checkInDate").value;
         const co = document.getElementById("checkOutDate").value;
         if (!ci || !co) {
             alert("Vui lòng chọn ngày Check In và Check Out");
             return;
         }
         window.location.href = `/Bookings/BookRoom?roomId=${roomId}&checkIn=${ci}&checkOut=${co}`;
     });

     // Khởi tạo
     const today = new Date().toISOString().split('T')[0];
     document.getElementById("checkInDate").min = today;
     document.getElementById("checkOutDate").min = today;

     // Ban đầu: nút mờ đi
     document.getElementById("btnBookNow").style.display = "block";
     document.getElementById("btnBookNow").disabled = true;
     document.getElementById("btnBookDisabled").style.display = "none";
</script>
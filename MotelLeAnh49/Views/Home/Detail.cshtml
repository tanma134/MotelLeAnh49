@model MotelLeAnh49.Models.Room
@{
    ViewData["Title"] = "Chi tiết phòng";
}

<style>
    .room-detail-section {
        padding: 50px 0;
    }

    .room-gallery {
        margin-bottom: 30px;
    }

    .main-image {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .thumbnail-gallery {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        overflow-x: auto;
    }

    .thumbnail {
        width: 120px;
        height: 80px;
        object-fit: cover;
        border-radius: 5px;
        cursor: pointer;
        transition: all 0.3s ease;
        border: 3px solid transparent;
    }

        .thumbnail:hover,
        .thumbnail.active {
            border-color: var(--primary-color);
            transform: scale(1.05);
        }

    .room-info {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .room-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--secondary-color);
        margin-bottom: 10px;
    }

    .room-type {
        color: var(--primary-color);
        font-size: 1.2rem;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .price-box {
        background: linear-gradient(135deg,var(--primary-color) 0%,#c09d2e 100%);
        padding: 25px;
        border-radius: 10px;
        color: white;
        text-align: center;
        margin: 30px 0;
    }

        .price-box .price {
            font-size: 2.5rem;
            font-weight: 700;
            margin: 10px 0;
        }

    .features-list {
        list-style: none;
        padding: 0;
    }

        .features-list li {
            padding: 15px 0;
            border-bottom: 1px solid #eee;
            display: flex;
            align-items: center;
        }

        .features-list i {
            color: var(--primary-color);
            font-size: 1.3rem;
            margin-right: 15px;
            width: 30px;
        }

    .booking-sidebar {
        position: sticky;
        top: 100px;
    }

    .booking-card {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .related-rooms {
        background: #f8f9fa;
        padding: 60px 0;
        margin-top: 50px;
    }
</style>

<div class="room-detail-section">
    <div class="container">
        <div class="row">

            <!-- LEFT -->
            <div class="col-lg-8">

                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="breadcrumb-item active">Chi tiết phòng</li>
                    </ol>
                </nav>

                <div class="room-gallery">

                    <img id="mainImage"
                         src="@(Model?.RoomImages?.FirstOrDefault()?.ImagePath ?? "https://images.unsplash.com/photo-1611892440504-42a792e24d32?w=1200")"
                         class="main-image" />

                    @if (Model?.RoomImages != null && Model.RoomImages.Any())
                    {
                        <div class="thumbnail-gallery">
                            @foreach (var image in Model.RoomImages)
                            {
                                <img src="@image.ImagePath"
                                     class="thumbnail"
                                     onclick="changeMainImage(this.src)" />
                            }
                        </div>
                    }
                </div>

                <div class="room-info">

                    <h1 class="room-title">
                        <i class="fas fa-door-open me-2"></i>
                        Phòng @Model?.RoomNumber
                    </h1>

                    <p class="room-type">
                        <i class="fas fa-tag me-2"></i>
                        @Model?.RoomType
                    </p>

                    <div class="price-box">
                        <p><i class="fas fa-moon me-2"></i>Giá thuê qua đêm</p>
                        <div class="price">
                            @(Model?.OvernightPrice.ToString("N0")) đ
                        </div>
                        <small>/ đêm</small>
                    </div>

                    <h4 class="mt-4 mb-3">
                        <i class="fas fa-list me-2"></i>Tiện nghi phòng
                    </h4>

                    <ul class="features-list">
                        <li><i class="fas fa-bed"></i>Giường cao cấp</li>
                        <li><i class="fas fa-wifi"></i>WiFi miễn phí</li>
                        <li><i class="fas fa-wind"></i>Điều hòa</li>
                        <li><i class="fas fa-tv"></i>Smart TV</li>
                        <li><i class="fas fa-shower"></i>Phòng tắm nóng lạnh</li>
                    </ul>

                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-lg-4">

                <div class="booking-sidebar">
                    <div class="booking-card">

                        <h4>
                            <i class="fas fa-calendar-check me-2"></i>
                            Đặt phòng ngay
                        </h4>

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success">
                                @TempData["Success"]
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger">
                                @TempData["Error"]
                            </div>
                        }

                        @if (ViewBag.CustomerId == null)
                        {
                            <a asp-controller="Auth"
                               asp-action="Login"
                               class="btn btn-gold w-100 mb-3">
                                Đăng nhập để đặt phòng
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Bookings"
                               asp-action="BookRoom"
                               asp-route-roomId="@Model.Id"
                               class="btn btn-gold w-100 mb-3">
                                <i class="fas fa-check-circle me-2"></i>Đặt phòng ngay
                            </a>
                        }

                        <a href="tel:0909999999"
                           class="btn btn-outline-dark w-100">
                            <i class="fas fa-phone me-2"></i>
                            Gọi: 0909 999 999
                        </a>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function changeMainImage(src){
    document.getElementById('mainImage').src = src;
    }
</script>
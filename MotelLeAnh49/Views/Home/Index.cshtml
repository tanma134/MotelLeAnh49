@model IEnumerable<MotelLeAnh49.Models.Room>
@{
    ViewData["Title"] = "Trang chủ";
}
<style>
    .about-img {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }

    /* ====== FLOATING CHAT WIDGET ====== */
    #chat-fab {
        position: fixed;
        bottom: 28px;
        right: 28px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #c9a84c;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(201,168,76,.45);
        z-index: 9999;
        transition: transform .2s, background .15s;
    }

        #chat-fab:hover {
            background: #e8c97a;
            transform: scale(1.07);
        }

        #chat-fab svg {
            width: 22px;
            height: 22px;
            fill: none;
            stroke: #1a1915;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    #chat-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #e74c3c;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    #chat-box {
        position: fixed;
        bottom: 96px;
        right: 28px;
        width: 360px;
        height: 520px;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: #0e0d0b;
        border: .5px solid #3a3930;
        box-shadow: 0 16px 48px rgba(0,0,0,.6);
        z-index: 9998;
        transform: scale(.92) translateY(20px);
        opacity: 0;
        transition: transform .28s cubic-bezier(.34,1.56,.64,1), opacity .2s;
        pointer-events: none;
        font-family: 'DM Mono', 'Courier New', monospace;
    }

        #chat-box.cx-open {
            transform: scale(1) translateY(0);
            opacity: 1;
            pointer-events: all;
        }

    .cx-header {
        padding: 14px 16px;
        background: #1a1915;
        border-bottom: .5px solid #3a3930;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .cx-icon {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #c9a84c;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }

    .cx-title {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 14px;
        color: #f0ead8;
        line-height: 1.2;
    }

    .cx-sub {
        font-size: 10px;
        color: #8a8674;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-top: 2px;
    }

    .cx-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4caf7d;
        margin-left: auto;
        flex-shrink: 0;
    }

    .cx-close-btn {
        margin-left: 8px;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: transparent;
        border: .5px solid #3a3930;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #8a8674;
        font-size: 13px;
        line-height: 1;
        transition: background .15s;
        flex-shrink: 0;
    }

        .cx-close-btn:hover {
            background: #2e2d27;
            color: #f0ead8;
        }

    .cx-msgs {
        flex: 1;
        overflow-y: auto;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        scrollbar-width: thin;
        scrollbar-color: #3a3930 transparent;
    }

        .cx-msgs::-webkit-scrollbar {
            width: 4px;
        }

        .cx-msgs::-webkit-scrollbar-thumb {
            background: #3a3930;
            border-radius: 4px;
        }

    .cx-msg {
        display: flex;
        flex-direction: column;
        max-width: 86%;
    }

        .cx-msg.user {
            align-self: flex-end;
            align-items: flex-end;
        }

        .cx-msg.ai {
            align-self: flex-start;
        }

    .cx-lbl {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #8a8674;
        margin-bottom: 3px;
    }

    .cx-msg.user .cx-lbl {
        color: #a07a2a;
    }

    .cx-bubble {
        padding: 9px 13px;
        border-radius: 12px;
        font-size: 12.5px;
        line-height: 1.6;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .cx-msg.user .cx-bubble {
        background: #2a2615;
        border: .5px solid #c9a84c;
        color: #f0ead8;
        border-bottom-right-radius: 3px;
    }

    .cx-msg.ai .cx-bubble {
        background: #1e1e1a;
        border: .5px solid #3a3930;
        color: #ccc8b8;
        border-bottom-left-radius: 3px;
    }

    .cx-typing-dots {
        display: flex;
        gap: 4px;
        padding: 11px 13px;
        align-items: center;
    }

        .cx-typing-dots span {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: #c9a84c;
            animation: cxBlink 1.2s ease-in-out infinite;
        }

            .cx-typing-dots span:nth-child(2) {
                animation-delay: .2s;
            }

            .cx-typing-dots span:nth-child(3) {
                animation-delay: .4s;
            }


    @@keyframes cxBlink {
        0%

    {
        opacity: .2;
    }

    40% {
        opacity: 1;
    }

    100% {
        opacity: .2;
    }

    }
    

    .cx-composer {
        border-top: .5px solid #3a3930 !important;
        padding: 12px 14px !important;
        display: flex !important;
        flex-direction: row !important;
        align-items: flex-end !important;
        gap: 8px !important;
        background: #1a1915 !important;
        flex-shrink: 0 !important;
        box-sizing: border-box !important;
    }

        .cx-composer textarea {
            flex: 1 1 auto !important;
            min-width: 0 !important;
            background: #2e2d27 !important;
            border: .5px solid #3a3930 !important;
            border-radius: 10px !important;
            padding: 8px 11px !important;
            font-family: 'DM Mono', 'Courier New', monospace !important;
            font-size: 12.5px !important;
            color: #f0ead8 !important;
            resize: none !important;
            outline: none !important;
            min-height: 38px !important;
            max-height: 110px !important;
            height: 38px !important;
            line-height: 1.5 !important;
            transition: border-color .2s !important;
            box-sizing: border-box !important;
            display: block !important;
        }

            .cx-composer textarea::placeholder {
                color: #8a8674;
            }

            .cx-composer textarea:focus {
                border-color: #c9a84c !important;
                box-shadow: none !important;
            }

    .cx-send-btn {
        width: 36px !important;
        height: 36px !important;
        min-width: 36px !important;
        border-radius: 50% !important;
        background: #c9a84c !important;
        border: none !important;
        cursor: pointer !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        flex-shrink: 0 !important;
        transition: background .15s, transform .1s;
        padding: 0 !important;
    }

        .cx-send-btn:hover {
            background: #e8c97a !important;
        }

        .cx-send-btn:active {
            transform: scale(.93);
        }

        .cx-send-btn:disabled {
            opacity: .45 !important;
            cursor: not-allowed !important;
        }

        .cx-send-btn svg {
            width: 14px !important;
            height: 14px !important;
            fill: none !important;
            stroke: #1a1915 !important;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
</style>

<!-- HERO SLIDER -->
<div id="heroCarousel" class="carousel slide hero-slider" data-bs-ride="carousel" data-bs-interval="5000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="@Url.Content("~/images/rooms/ninhkieu.jpg")"
                 alt="Ben Ninh Kieu Can Tho">
            <div class="carousel-overlay">
                <h1 class="fade-in-up">MOTEL LÊ ANH 49</h1>
                <p class="fade-in-up">Gần Bến Ninh Kiều - Trung tâm Cần Thơ</p>
                <a href="#booking" class="btn btn-gold fade-in-up">Đặt phòng ngay</a>
            </div>
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/images/rooms/chonoicairang.jpg")"
                 alt="Cho Noi Cai Rang Can Tho">
            <div class="carousel-overlay">
                <h1 class="fade-in-up">CHỢ NỔI CÁI RĂNG</h1>
                <p class="fade-in-up">Trải nghiệm nét văn hóa sông nước đặc trưng miền Tây</p>
                <a href="#rooms" class="btn btn-gold fade-in-up">Khám phá phòng</a>
            </div>
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/images/rooms/chodemninhkieu.jpg")"
                 alt="Cho Dem Ninh Kieu Can Tho">
            <div class="carousel-overlay">
                <h1 class="fade-in-up">CHỢ ĐÊM NINH KIỀU</h1>
                <p class="fade-in-up">Thiên đường ẩm thực và mua sắm sôi động giữa lòng Cần Thơ</p>
                <a href="#rooms" class="btn btn-gold fade-in-up">Khám phá phòng</a>
            </div>
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<section class="booking-section" id="booking">
    <div class="container">
        <div class="booking-form">
            <h3>
                <i class="fas fa-calendar-check me-2"></i>
                Đặt phòng trực tuyến
            </h3>

            <form id="searchForm">
                <div class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label">Ngày nhận phòng</label>
                        <input type="date" name="CheckIn" class="form-control" required>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Ngày trả phòng</label>
                        <input type="date" name="CheckOut" class="form-control" required>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Người lớn</label>
                        <select name="Adults" class="form-select">
                            <option value="1">1</option>
                            <option value="2" selected>2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Trẻ em</label>
                        <select name="Children" class="form-select">
                            <option value="0" selected>0</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-gold w-100">
                            <i class="fas fa-search me-2"></i>Tìm phòng
                        </button>
                    </div>

                </div>
            </form>

        </div>
    </div>
</section>

<!-- Kết quả hiển thị -->
<div class="container mt-4">
    <div id="roomResults"></div>
</div>

<!-- ABOUT SECTION -->
<section class="about-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="row">
                    <div class="col-6">
                        <img src="@Url.Content("~/images/rooms/anhnhanghi.jpg")" class="about-img">
                    </div>
                    <div class="col-6">
                        <img src="@Url.Content("~/images/rooms/anhdem.jpg")" class="about-img">
                    </div>
                </div>
            </div>
            <div class="col-lg-6 about-content">
                <h3>Chào mừng đến với Motel Lê Anh 49</h3>
                <p>
                    Với hơn 10 năm kinh nghiệm trong lĩnh vực khách sạn và dịch vụ lưu trú,
                    Motel Lê Anh 49 tự hào là địa chỉ tin cậy cho mọi nhu cầu nghỉ ngơi của bạn.
                </p>
                <p>
                    Chúng tôi cung cấp các phòng nghỉ được thiết kế hiện đại, trang bị đầy đủ tiện nghi,
                    kết hợp với đội ngũ nhân viên chuyên nghiệp, tận tâm luôn sẵn sàng phục vụ 24/7.
                </p>
                <ul class="about-features">
                    <li><i class="fas fa-check-circle"></i> Phòng sạch sẽ, tiện nghi hiện đại</li>
                    <li><i class="fas fa-check-circle"></i> Giá cả cạnh tranh, minh bạch</li>
                    <li><i class="fas fa-check-circle"></i> Dịch vụ chuyên nghiệp 24/7</li>
                    <li><i class="fas fa-check-circle"></i> Vị trí thuận lợi, giao thông tiện lợi</li>
                    <li><i class="fas fa-check-circle"></i> An ninh đảm bảo, camera giám sát</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- EVENT SECTION -->
<section class="py-5" id="events" style="background: var(--bs-light, #f8f9fa);">
    <div class="container">
        <div class="section-title">
            <h2>Sự kiện nổi bật</h2>
            <p>Khám phá các sự kiện đặc sắc tại Motel Lê Anh 49</p>
        </div>

        @{
            var events = ViewBag.Events as IEnumerable<MotelLeAnh49.Models.Event>;
        }

        @if (events != null && events.Any())
        {
            <div class="row">
                @foreach (var ev in events.Take(3))
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm border-0 room-card">
                            <div class="card-body d-flex flex-column p-4">

                                <div class="d-flex align-items-center mb-3">
                                    <div style="width:48px; height:48px; border-radius:10px; overflow:hidden; flex-shrink:0;">
                                        <img src="@ev.ImageUrl"
                                             style="width:100%; height:100%; object-fit:cover;">
                                    </div>
                                    <div class="ms-3">
                                        <span class="badge"
                                              style="background:#fff3cd; color:#856404;
                                                     font-size:0.75rem; font-weight:500;">
                                            <i class="far fa-clock me-1"></i>
                                            @ev.EventDate.ToString("dd/MM/yyyy")
                                        </span>
                                    </div>
                                </div>

                                <h5 class="fw-semibold mb-2">@ev.Title</h5>

                                @if (!string.IsNullOrEmpty(ev.Location))
                                {
                                    <p class="text-muted mb-2" style="font-size:0.9rem;">
                                        <i class="fas fa-map-marker-alt me-1"></i>
                                        @ev.Location
                                    </p>
                                }

                                @if (!string.IsNullOrEmpty(ev.Description))
                                {
                                    <p class="text-muted flex-grow-1" style="font-size:0.9rem; line-height:1.6;">
                                        @(ev.Description.Length > 100
                                            ? ev.Description.Substring(0, 100) + "..."
                                            : ev.Description)
                                    </p>
                                }

                                <div class="mt-3 d-flex gap-2">
                                    <a asp-controller="Events"
                                       asp-action="Details"
                                       asp-route-id="@ev.EventId"
                                       class="btn btn-outline-secondary btn-sm flex-grow-1">
                                        <i class="fas fa-eye me-1"></i>Chi tiết
                                    </a>
                                    <a asp-controller="Events"
                                       asp-action="Join"
                                       asp-route-id="@ev.EventId"
                                       class="btn btn-gold btn-sm flex-grow-1">
                                        <i class="fas fa-user-plus me-1"></i>Tham gia
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-2">
                <a asp-controller="Events" asp-action="List"
                   class="btn btn-outline-secondary px-4">
                    <i class="fas fa-calendar-alt me-2"></i>Xem tất cả sự kiện
                </a>
            </div>
        }
        else
        {
            <div class="text-center py-4 text-muted">
                <i class="fas fa-calendar-times fa-2x mb-3 d-block"></i>
                Hiện chưa có sự kiện nào.
            </div>
        }
    </div>
</section>

<!-- ROOM LIST SECTION -->
<section class="py-5" id="rooms">
    <div class="container">
        <div class="section-title">
            <h2>Danh sách phòng</h2>
            <p>Khám phá các loại phòng phù hợp với nhu cầu của bạn</p>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                @foreach (var room in Model)
                {
                    var imagePath = room.RoomImages != null && room.RoomImages.Any()
                    ? room.RoomImages.First().ImagePath
                    : "/images/rooms/phongthuong.jpg";

                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card room-card">
                            <div style="overflow: hidden;">
                                <img src="@Url.Content(imagePath)"
                                     class="card-img-top room-img"
                                     alt="@room.RoomNumber">
                            </div>

                            <div class="card-body">
                                <h5>
                                    <i class="fas fa-door-open me-2"></i>
                                    @room.RoomNumber
                                </h5>

                                <p class="text-muted mb-2">
                                    <i class="fas fa-tag me-1"></i>
                                    @room.RoomType
                                </p>

                                <ul class="room-features">
                                    <li><i class="fas fa-bed"></i> Giường đơn/đôi</li>
                                    <li><i class="fas fa-wifi"></i> WiFi miễn phí</li>
                                    <li><i class="fas fa-wind"></i> Điều hòa nhiệt độ</li>
                                    <li><i class="fas fa-tv"></i> TV màn hình phẳng</li>
                                </ul>

                                <div class="price">
                                    @room.OvernightPrice.ToString("N0") đ
                                    <small class="d-block text-muted" style="font-size: 0.9rem;">/ đêm</small>
                                </div>

                                <a asp-controller="Home"
                                   asp-action="Detail"
                                   asp-route-id="@room.Id"
                                   class="btn btn-view-detail w-100 mt-3">
                                    <i class="fas fa-eye me-2"></i>Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p>Hiện chưa có phòng nào.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- SERVICES SECTION -->
<section class="services-section" id="services">
    <div class="container">
        <div class="section-title">
            <h2>Dịch vụ của chúng tôi</h2>
            <p>Trải nghiệm các dịch vụ tiện ích tại Motel Lê Anh 49</p>
        </div>

        <div class="row">
            @{
                var services = ViewBag.Services as IEnumerable<MotelLeAnh49.Models.ServiceItem>;
            }

            @if (services != null && services.Any())
            {
                @foreach (var s in services)
                {
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="service-card">

                            <div style="overflow: hidden;">
                                <img src="@(string.IsNullOrEmpty(s.ImageUrl)
                                            ? "https://via.placeholder.com/600x400"
                                            : s.ImageUrl)"
                                     alt="@s.Name"
                                     style="width:100%; height:200px; object-fit:cover;">
                            </div>

                            <div class="card-body">
                                <div class="service-icon">
                                    @{
                                        string icon = "bi bi-arrow-through-heart";
                                        if (s.Name.ToLower().Contains("wifi")) icon = "bi bi-wifi";
                                        else if (s.Name.ToLower().Contains("giặt")) icon = "bi bi-basket";
                                        else if (s.Name.ToLower().Contains("hồ")) icon = "bi bi-water";
                                    }
                                    <i class="@icon"></i>
                                </div>

                                <h4>@s.Name</h4>

                                <p>
                                    @(string.IsNullOrEmpty(s.Description)
                                        ? "Dịch vụ chất lượng cao tại motel"
                                        : s.Description)
                                </p>

                                <p style="color:#e67e22; font-weight:600;">
                                    @if (s.Price <= 0)
                                    {
                                        <span style="color:#27ae60; font-weight:600;">Miễn phí</span>
                                    }
                                    else
                                    {
                                        <span style="color:#e67e22; font-weight:600;">
                                            @s.Price.ToString("N0") đ
                                        </span>
                                    }
                                </p>
                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p>Hiện chưa có dịch vụ nào.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- PROMOTION SECTION -->
<section class="promotion-section" id="promotion">
    <div class="container">
        <div class="section-title">
            <h2>Khuyến mãi đặc biệt</h2>
            <p>Đừng bỏ lỡ các ưu đãi hấp dẫn từ chúng tôi</p>
        </div>

        <div class="row">
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="promotion-card">

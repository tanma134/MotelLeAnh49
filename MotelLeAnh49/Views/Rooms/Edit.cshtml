@model MotelLeAnh49.Models.Room
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        padding: 20px;
    }

    .form-container {
        max-width: 650px;
        margin: auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        text-align: center;
        border-bottom: 3px solid #f39c12;
        padding-bottom: 10px;
    }

    .validation-summary {
        background: #ffe6e6;
        color: #e74c3c;
        padding: 12px;
        margin-bottom: 20px;
        border-left: 5px solid #e74c3c;
        border-radius: 8px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 5px;
    }

    input {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 2px solid #ddd;
    }

        input:focus {
            border-color: #f39c12;
        }

        /* 🔥 lỗi */
        input.input-validation-error {
            border-color: #e74c3c;
            background: #fff5f5;
        }

    .validation-error {
        color: #e74c3c;
        font-size: 13px;
    }

    .button-group {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

    button {
        flex: 1;
        padding: 12px;
        background: #f39c12;
        color: white;
        border: none;
        border-radius: 8px;
    }

    .btn-back {
        flex: 1;
        padding: 12px;
        background: gray;
        color: white;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
    }
</style>

<div class="form-container">
    <h2>✏️ Sửa phòng</h2>

    <!-- 🔥 HIỂN THỊ LỖI -->
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="AdminId" />

        <div class="form-group">
            <label>Số phòng</label>
            <input asp-for="RoomNumber" />
            <span asp-validation-for="RoomNumber" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Loại phòng</label>
            <input asp-for="RoomType" />
            <span asp-validation-for="RoomType" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá qua đêm</label>
            <input asp-for="OvernightPrice" type="number" />
            <span asp-validation-for="OvernightPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá ngày</label>
            <input asp-for="DayPrice" type="number" />
            <span asp-validation-for="DayPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá giờ đầu</label>
            <input asp-for="FirstHourPrice" type="number" />
            <span asp-validation-for="FirstHourPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá giờ tiếp</label>
            <input asp-for="NextHourPrice" type="number" />
            <span asp-validation-for="NextHourPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Số khách</label>
            <input asp-for="MaxGuests" type="number" />
            <span asp-validation-for="MaxGuests" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Phụ thu</label>
            <input asp-for="ExtraGuestFee" type="number" />
            <span asp-validation-for="ExtraGuestFee" class="validation-error"></span>
        </div>

        <!-- 🔥 ẢNH HIỆN TẠI -->
        <h4>📸 Ảnh hiện tại</h4>

        @if (Model.RoomImages != null && Model.RoomImages.Any())
        {
            foreach (var img in Model.RoomImages)
            {
                <div style="margin-bottom:10px;">
                    <img src="@img.ImagePath" width="120" />
                    <br />
                    <input type="checkbox" name="DeletedImageIds" value="@img.Id" />
                    Xóa ảnh
                </div>
            }
        }
        else
        {
            <p>Chưa có ảnh</p>
        }

        <!-- 🔥 THÊM ẢNH -->
        <div class="form-group">
            <label>Thêm ảnh mới</label>
            <input type="file" name="Images" multiple accept="image/*" />
        </div>

        <div class="button-group">
            <button type="submit">💾 Cập nhật</button>
            <a asp-action="Index" class="btn-back">⬅ Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model IEnumerable<MotelLeAnh49.Models.Room>

@if (!Model.Any())
{
    <div class="alert alert-warning mt-4">
        Không có phòng phù hợp.
    </div>
}
else
{
    <div class="row mt-4">

        @foreach (var room in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm">

                    <div class="card-body">
                        <h5>Phòng @room.RoomNumber</h5>

                        <p>Loại phòng: @room.RoomType</p>

                        <p>Tối đa: @room.MaxGuests khách</p>

                        <p class="text-success">
                            @room.DayPrice.ToString("N0") VND / ngày
                        </p>

                        <a href="/Rooms/Detail/@room.Id"
                           class="btn btn-gold">
                            Xem phòng
                        </a>
                    </div>

                </div>
            </div>
        }

    </div>
}
@model MotelLeAnh49.Models.Room

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        margin: 0;
        padding: 20px;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        font-size: 28px;
        text-align: center;
        border-bottom: 3px solid #3498db;
        padding-bottom: 10px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        color: #555;
        font-weight: 600;
        font-size: 14px;
    }

    input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 15px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

        input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

    .button-group {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    button {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: #95a5a6;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        text-align: center;
        transition: all 0.3s ease;
        display: inline-block;
    }

        .btn-back:hover {
            background: #7f8c8d;
            transform: translateY(-2px);
        }
</style>

<div class="form-container">
    <h2>➕ Thêm phòng mới</h2>

    <form asp-action="Create"
          method="post"
          enctype="multipart/form-data">

        <div class="form-group">
            <label>Số phòng</label>
            <input asp-for="RoomNumber" placeholder="VD: P101" required />
        </div>

        <div class="form-group">
            <label>Loại phòng</label>
            <input asp-for="RoomType" placeholder="VD: Standard, VIP" required />
        </div>

        <div class="form-group">
            <label>Giá qua đêm (VNĐ)</label>
            <input asp-for="OvernightPrice" type="number" required />
        </div>

        <div class="form-group">
            <label>Giá ngày (VNĐ)</label>
            <input asp-for="DayPrice" type="number" required />
        </div>

        <div class="form-group">
            <label>Giá giờ đầu (VNĐ)</label>
            <input asp-for="FirstHourPrice" type="number" required />
        </div>

        <div class="form-group">
            <label>Giá giờ tiếp theo (VNĐ)</label>
            <input asp-for="NextHourPrice" type="number" required />
        </div>

        <div class="form-group">
            <label>Số khách tối đa</label>
            <input asp-for="MaxGuests" type="number" required />
        </div>

        <div class="form-group">
            <label>Phụ thu thêm người (VNĐ)</label>
            <input asp-for="ExtraGuestFee" type="number" required />
        </div>

        <!-- 🔥 THÊM PHẦN UPLOAD ẢNH -->
        <div class="form-group">
            <label>Ảnh phòng</label>
            <input type="file"
                   name="Images"
                   multiple
                   accept="image/*"
                   class="form-control" />
            <small>Có thể chọn nhiều ảnh</small>
        </div>

        <div class="button-group">
            <button type="submit">💾 Lưu phòng</button>
            <a asp-action="Index" class="btn-back">⬅ Quay lại</a>
        </div>
    </form>
</div>
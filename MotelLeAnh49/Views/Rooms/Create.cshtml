@model MotelLeAnh49.Models.Room
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        margin: 0;
        padding: 20px;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        text-align: center;
        border-bottom: 3px solid #3498db;
        padding-bottom: 10px;
    }

    .validation-summary {
        background: #ffe6e6;
        color: #e74c3c;
        padding: 12px;
        margin-bottom: 20px;
        border-left: 5px solid #e74c3c;
        border-radius: 8px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        margin-bottom: 6px;
        display: block;
    }

    input {
        width: 100%;
        padding: 12px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        transition: 0.3s;
    }

        input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

        /* 🔥 input lỗi */
        input.input-validation-error {
            border-color: #e74c3c;
            background: #fff5f5;
        }

    .validation-error {
        color: #e74c3c;
        font-size: 13px;
        margin-top: 5px;
        display: block;
    }

    button {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
    }

    .button-group {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: gray;
        color: white;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
    }
</style>

<div class="form-container">
    <h2>➕ Thêm phòng mới</h2>

    <!-- 🔥 HIỂN THỊ LỖI -->
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="form-group">
            <label>Số phòng</label>
            <input asp-for="RoomNumber" placeholder="VD: P101" />
            <span asp-validation-for="RoomNumber" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Loại phòng</label>
            <input asp-for="RoomType" />
            <span asp-validation-for="RoomType" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá qua đêm</label>
            <input asp-for="OvernightPrice" type="number" />
            <span asp-validation-for="OvernightPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá ngày</label>
            <input asp-for="DayPrice" type="number" />
            <span asp-validation-for="DayPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá giờ đầu</label>
            <input asp-for="FirstHourPrice" type="number" />
            <span asp-validation-for="FirstHourPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Giá giờ tiếp</label>
            <input asp-for="NextHourPrice" type="number" />
            <span asp-validation-for="NextHourPrice" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Số khách</label>
            <input asp-for="MaxGuests" type="number" />
            <span asp-validation-for="MaxGuests" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Phụ thu</label>
            <input asp-for="ExtraGuestFee" type="number" />
            <span asp-validation-for="ExtraGuestFee" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Ảnh phòng</label>
            <input type="file" name="Images" multiple accept="image/*" />
        </div>

        <div class="button-group">
            <button type="submit">💾 Lưu</button>
            <a asp-action="Index" class="btn-back">⬅ Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin - Motel Lê Anh 49</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
        body {
            overflow-x: hidden;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            background: #1f2937;
            color: white;
        }

            .sidebar a {
                color: white;
                display: block;
                padding: 12px 20px;
                text-decoration: none;
            }

                .sidebar a:hover {
                    background: #374151;
                }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .sidebar-title {
            font-size: 20px;
            padding: 20px;
            font-weight: bold;
            background: #111827;
        }
    </style>
</head>

<body>

    <div class="sidebar">

        <div class="sidebar-title">
            Admin Panel
        </div>

        <a asp-controller="Dashboard" asp-action="Index">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>

        <a asp-controller="Bookings" asp-action="Index">
            <i class="fas fa-calendar-check"></i> Manage Booking
        </a>

        <a asp-controller="Customers" asp-action="Index">
            <i class="fas fa-users"></i> Manage Customer
        </a>

        <a asp-controller="Rooms" asp-action="Index">
            <i class="fas fa-bed"></i> Manage Room
        </a>

        <a asp-controller="ServiceItems" asp-action="Index">
            <i class="fas fa-concierge-bell"></i> Manage Service
        </a>

        <a asp-controller="Events" asp-action="Index">
            <i class="fas fa-tags"></i> Manage Event
        </a>

        <a asp-controller="Auth" asp-action="Logout">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>

    </div>


    <!-- CONTENT -->
    <div class="content">

        <h3 class="mb-4">@ViewData["Title"]</h3>

        @RenderBody()

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


    <!-- SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/roomHub")
            .build();

                connection.on("RoomUpdated", function () {

            const path = window.location.pathname.toLowerCase();

            if (path.includes("/rooms") && !path.includes("create") && !path.includes("edit") && !path.includes("delete")) {
                location.reload();
            }

        });

        connection.start().catch(err => console.error(err));

    </script>

    @RenderSection("Scripts", required: false)
</body>

</html>
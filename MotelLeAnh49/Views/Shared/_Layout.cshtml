<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Motel Lê Anh 49</title>

    <!-- FIX LOGO ICON -->
    <link rel="icon" type="image/jpeg" href="@Url.Content("~/images/rooms/logo.jpg")">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Roboto:wght@300;400;500;700&display=swap"
          rel="stylesheet">
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center"
               asp-controller="Home"
               asp-action="Index">

                <!-- FIX LOGO -->
                <img src="@Url.Content("~/images/rooms/logo.jpg")"
                     alt="Logo"
                     style="height: 40px; margin-right: 10px;">

                MOTEL LÊ ANH 49
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">
                            <i class="fas fa-home me-1"></i> Trang chủ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#services">
                            <i class="fas fa-concierge-bell me-1"></i> Dịch vụ
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#promotion">
                            <i class="fas fa-tags me-1"></i> Khuyến mãi
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#contact">
                            <i class="fas fa-phone me-1"></i> Liên hệ
                        </a>
                    </li>

                    <!-- LOGIN AREA -->
                    @if (Context.Session.GetString("FullName") == null)
                    {
                        <li class="nav-item">
                            <a class="nav-link btn btn-success text-white ms-2 px-3"
                               asp-controller="Auth"
                               asp-action="Login">
                                <i class="fas fa-user"></i> Đăng nhập
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown ms-3">
                            <a class="nav-link dropdown-toggle text-warning"
                               href="#"
                               data-bs-toggle="dropdown">

                                <i class="fas fa-user-circle"></i>
                                Xin chào, @Context.Session.GetString("FullName")

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Customer"
                                       asp-action="Profile">
                                        Hồ sơ
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Bookings"
                                       asp-action="History">
                                        Lịch sử đặt phòng
                                    </a>
                                </li>

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <a class="dropdown-item text-danger"
                                       asp-controller="Auth"
                                       asp-action="Logout">
                                        Đăng xuất
                                    </a>
                                </li>

                            </ul>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <div style="margin-top:70px;">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row">

                <!-- About -->
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5>
                        <img src="@Url.Content("~/images/rooms/logo.jpg")"
                             alt="Logo"
                             style="height: 30px; margin-right: 10px; vertical-align: middle;">
                        MOTEL LÊ ANH 49
                    </h5>

                    <p>
                        Chúng tôi cam kết mang đến cho bạn không gian nghỉ ngơi
                        thoải mái nhất với phòng đẹp, giá cả hợp lý và dịch vụ
                        chuyên nghiệp 24/7.
                    </p>
                </div>

                <!-- Links -->
                <div class="col-lg-2 col-md-6 mb-4">
                    <h5>Liên kết</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index" class="text-light">Trang chủ</a></li>
                        <li><a asp-controller="Rooms" asp-action="Index" class="text-light">Danh sách phòng</a></li>
                        <li><a href="#services" class="text-light">Dịch vụ</a></li>
                        <li><a href="#promotion" class="text-light">Khuyến mãi</a></li>
                        <li><a href="#contact" class="text-light">Liên hệ</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <!-- Contact -->
                <div class="col-lg-3 col-md-6 mb-4" id="contact">
                    <h5>Thông tin liên hệ</h5>
                    <p><i class="fas fa-map-marker-alt"></i> Số 49 đường Trần Văn Ơn, phường Cái Khế, quận Ninh Kiều, thành phố Cần Thơ </p>
                    <p><i class="fas fa-phone"></i> 02923 898 152</p>
                    <p><i class="fas fa-clock"></i> Phục vụ 24/7</p>

                    <!-- Social Links -->
                    <div class="social-links mt-3">
                        <a href="https://www.facebook.com/MotelLeAnh49" target="_blank" title="Facebook">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://zalo.me/0915272424" target="_blank" title="Zalo">
                            <i class="fas fa-comment-dots"></i>
                        </a>
                        <a href="mailto:honganhct2019@gmail.com" title="Email">
                            <i class="fas fa-envelope"></i>
                        </a>
                    </div>
                </div>

            </div>

            <hr class="bg-light" />

            <div class="text-center">
                &copy; 2026 Motel Lê Anh 49
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>

</html>

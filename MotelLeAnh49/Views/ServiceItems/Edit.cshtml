@model MotelLeAnh49.Models.ServiceItem

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        margin: 0;
        padding: 20px;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        font-size: 28px;
        text-align: center;
        border-bottom: 3px solid #f39c12;
        padding-bottom: 10px;
    }

    .validation-summary {
        background: #fff3cd;
        padding: 15px;
        margin-bottom: 20px;
        border-left: 4px solid #ffc107;
        border-radius: 8px;
        color: #856404;
    }

        .validation-summary:empty {
            display: none;
        }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        color: #555;
        font-weight: 600;
        font-size: 14px;
    }

    input, textarea {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
    }

    .preview-img {
        width: 120px;
        border-radius: 8px;
        margin-top: 10px;
    }

    .button-group {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    button {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        color: white;
        border: none;
        border-radius: 8px;
    }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: #95a5a6;
        color: white;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
    }
</style>

<div class="form-container">
    <h2>🛎️ Chỉnh sửa dịch vụ</h2>

    <!-- ✅ FIX: thêm enctype -->
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="ServiceItemId" />

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label>Tên dịch vụ</label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description"></textarea>
        </div>

        <div class="form-group">
            <label>Giá (VNĐ)</label>
            <input asp-for="Price" type="number" />
        </div>

        <!-- 🔥 ẢNH HIỆN TẠI -->
        <div class="form-group">
            <label>Ảnh hiện tại</label><br />
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="preview-img" id="oldImage" />
            }
            else
            {
                <p>Chưa có ảnh</p>
            }
        </div>

        <!-- 🔥 UPLOAD ẢNH MỚI -->
        <div class="form-group">
            <label>Thay ảnh mới</label>
            <input type="file" name="ImageFile" accept="image/*" />
            <img id="preview" class="preview-img" style="display:none;" />
        </div>

        <div class="form-group checkbox-group">
            <input asp-for="IsAvailable" type="checkbox" />
            <label>Sẵn sàng kinh doanh</label>
        </div>

        <div class="button-group">
            <button type="submit">✅ Cập nhật</button>
            <a asp-action="Index" class="btn-back">⬅ Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // preview ảnh mới
        const input = document.querySelector('input[name="ImageFile"]');
        const preview = document.getElementById("preview");
        const oldImage = document.getElementById("oldImage");

        input.addEventListener("change", function () {
            const file = this.files[0];

            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = "block";

                // ẩn ảnh cũ khi chọn ảnh mới
                if (oldImage) oldImage.style.display = "none";
            }
        });
    </script>
}
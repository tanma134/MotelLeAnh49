@model MotelLeAnh49.Models.ServiceItem

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        margin: 0;
        padding: 20px;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        font-size: 28px;
        text-align: center;
        border-bottom: 3px solid #3498db;
        padding-bottom: 10px;
    }

    .validation-summary {
        background: #fff3cd;
        padding: 15px;
        margin-bottom: 20px;
        border-left: 4px solid #ffc107;
        border-radius: 8px;
        color: #856404;
    }

        .validation-summary:empty {
            display: none;
        }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        color: #555;
        font-weight: 600;
        font-size: 14px;
    }

    input, textarea {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 15px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

        input:focus, textarea:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .button-group {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    button {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
    }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: #95a5a6;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        text-align: center;
    }

    .preview-img {
        width: 120px;
        border-radius: 8px;
        margin-top: 10px;
        display: none;
    }
</style>

<div class="form-container">
    <h2>➕ Thêm dịch vụ mới</h2>

    <!-- ✅ FIX: thêm enctype -->
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label>Tên dịch vụ</label>
            <input asp-for="Name" placeholder="VD: Nước suối, Giặt ủi..." />
            <span asp-validation-for="Name" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description" rows="3"></textarea>
        </div>

        <div class="form-group">
            <label>Giá (VNĐ)</label>
            <input asp-for="Price" type="number" value="" />
            <span asp-validation-for="Price" class="validation-error"></span>
        </div>

        <!-- 🔥 UPLOAD ẢNH TỪ MÁY -->
        <div class="form-group">
            <label>Ảnh dịch vụ</label>
            <input type="file" name="ImageFile" accept="image/*" />
            <img id="preview" class="preview-img" />
        </div>

        <div class="form-group checkbox-group">
            <input asp-for="IsAvailable" type="checkbox" />
            <label>Sẵn sàng kinh doanh</label>
        </div>

        <div class="button-group">
            <button type="submit">💾 Lưu dịch vụ</button>
            <a asp-action="Index" class="btn-back">⬅ Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // 🔥 preview ảnh từ máy
        const input = document.querySelector('input[name="ImageFile"]');
        const preview = document.getElementById("preview");

        input.addEventListener("change", function () {
            const file = this.files[0];

            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = "block";
            }
        });

        // validation chỉ hiện khi submit
        const form = document.querySelector("form");
        const summary = document.querySelector(".validation-summary");

        summary.style.display = "none";

        form.addEventListener("submit", function () {
            summary.style.display = "block";
        });
    </script>
}
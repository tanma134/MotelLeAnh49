@model IEnumerable<DataAccess.Models.Customer>
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa; /* Nền xám nhạt giống mẫu */
        margin: 0;
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 20px;
        font-size: 28px;
        border-bottom: 3px solid #3498db; /* Gạch chân xanh dương */
        padding-bottom: 10px;
        display: inline-block;
        font-weight: bold;
    }

    /* Nút thêm mới Gradient Xanh-Tím giống mẫu */
    .btn-add {
        display: inline-block;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white !important;
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        margin-bottom: 20px;
        transition: all 0.3s ease;
        font-weight: 600;
        border: none;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }

    /* Table Container & Shadows */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        border-radius: 8px;
        overflow: hidden;
        background: white;
    }

    /* Table Header Gradient */
    thead {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    th {
        padding: 15px 10px;
        text-align: center;
        font-weight: 600;
        font-size: 14px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* Body Rows & Hover */
    tbody tr {
        border-bottom: 1px solid #e0e0e0;
        transition: background 0.2s ease;
    }

        tbody tr:hover {
            background: #f8f9fa;
        }

        tbody tr:nth-child(even) {
            background: #fafbfc;
        }

            tbody tr:nth-child(even):hover {
                background: #f0f2f5;
            }

    td {
        padding: 14px 10px;
        text-align: center;
        color: #555;
        vertical-align: middle;
    }

        td b {
            color: #2c3e50;
            font-size: 15px;
        }

    /* Action Links Style */
    .action-link {
        color: #3498db;
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 4px;
        transition: all 0.2s ease;
        display: inline-block;
        font-size: 13px;
        font-weight: 500;
    }

        .action-link:hover {
            background: #3498db;
            color: white !important;
        }

    .delete-link {
        color: #e74c3c;
    }

        .delete-link:hover {
            background: #e74c3c;
            color: white !important;
        }

    .badge-info {
        background: #edf2f7;
        color: #4a5568;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: bold;
    }

    .btn-delete {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 15px;
        background-color: #fff;
        color: #e74c3c;
        border: 1px solid #e74c3c;
        border-radius: 6px;
        text-decoration: none; /* Bỏ cái gạch chân xanh xanh đi nè ba */
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .btn-delete:hover {
            background-color: #e74c3c;
            color: white;
            box-shadow: 0 2px 8px rgba(231, 76, 60, 0.3);
            text-decoration: none;
        }
</style>

<div class="container py-4">
    <h2>📋 QUẢN LÝ KHÁCH HÀNG MOTEL LÊ ANH 49</h2>

    <p>
        <a asp-action="Create" class="btn-add">➕ Thêm khách hàng</a>
    </p>

    <table>
        <thead>
            <tr>
                <th style="width: 50px;">STT</th>
                <th>Họ và Tên</th>
                <th>Số điện thoại</th>
                <th>Email</th>
                <th>CCCD/CMND</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@stt</td>
                    <td><b>@item.FullName</b></td>
                    <td>@item.Phone</td>
                    <td style="color: #718096;">@item.Email</td>
                    <td><span class="badge-info">@item.IdentityNumber</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-link">✏️ Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                            <i class="fa-solid fa-trash-can"></i> Xóa
                        </a>
                    </td>
                </tr>
                stt++;
            }
        </tbody>
    </table>
</div>
@model DataAccess.Models.Customer
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        margin: 0;
        padding: 20px;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        font-size: 28px;
        text-align: center;
        border-bottom: 3px solid #f39c12;
        padding-bottom: 10px;
    }

    /* Khối Debug lỗi */
    .debug-error {
        background: #ffe0e0;
        padding: 15px;
        margin-bottom: 20px;
        border-left: 4px solid #e74c3c;
        border-radius: 8px;
    }

        .debug-error b {
            color: #c0392b;
        }

        .debug-error ul {
            margin: 10px 0 0 0;
            padding-left: 20px;
        }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        color: #555;
        font-weight: 600;
        font-size: 14px;
    }

    input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 15px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

        input:focus {
            outline: none;
            border-color: #f39c12;
            box-shadow: 0 0 0 3px rgba(243, 156, 18, 0.1);
        }

    .validation-error {
        color: #e74c3c;
        font-size: 13px;
        margin-top: 5px;
        display: block;
    }

    .button-group {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    button {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(243, 156, 18, 0.4);
        }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: #95a5a6;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        text-align: center;
        display: inline-block;
        transition: all 0.3s ease;
    }
</style>

<div class="form-container">
    <h2>👤 Sửa thông tin khách hàng</h2>

    @if (ViewBag.DebugErrors != null)
    {
        <div class="debug-error">
            <b>🐛 LỖI MODELSTATE:</b>
            <ul>
                @foreach (string err in (List<string>)ViewBag.DebugErrors)
                {
                    <li>@err</li>
                }
            </ul>
        </div>
    }

    <form asp-controller="Customers" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        @* --- CÁC TRƯỜNG ẨN (ID VÀ KHÓA NGOẠI) --- *@
        <input type="Hidden" asp-for="Id" />
        <input type="Hidden" asp-for="AccountId" /> @* Đổi thành AccountId nếu Model dùng tên đó *@

        <div class="form-group">
            <label>Họ và Tên khách hàng</label>
            <input asp-for="FullName" placeholder="Nhập tên khách hàng..." />
            <span asp-validation-for="FullName" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Số điện thoại liên lạc</label>
            <input asp-for="Phone" placeholder="Ví dụ: 0912..." />
            <span asp-validation-for="Phone" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Địa chỉ Email</label>
            <input asp-for="Email" type="email" placeholder="example@gmail.com" />
            <span asp-validation-for="Email" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Địa chỉ thường trú</label>
            @* Đưa Address ra ngoài để người dùng cập nhật *@
            <input asp-for="Address" placeholder="Số nhà, tên đường..." />
            <span asp-validation-for="Address" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Số CCCD / CMND</label>
            <input asp-for="IdentityNumber" readonly />
            <span asp-validation-for="IdentityNumber" class="validation-error"></span>
        </div>
        <div class="button-group">
            <button type="submit">✅ Lưu thay đổi</button>
            <a asp-controller="Customers" asp-action="Index" class="btn-back">⬅ Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
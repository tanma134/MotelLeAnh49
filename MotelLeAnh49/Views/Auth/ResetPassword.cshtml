@{
    ViewData["Title"] = "Reset Password";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0d0d0f;
        --surface: #131317;
        --border: rgba(255,255,255,0.07);
        --gold: #c9a96e;
        --gold-light: #e8c98a;
        --text: #e8e4dc;
        --muted: #6b6763;
        --input-bg: #1a1a20;
        --danger: #e07070;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .reset-page {
        min-height: 70vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: var(--bg);
        font-family: 'DM Sans', sans-serif;
        position: relative;
        overflow: hidden;
        padding: 40px 16px;
    }

        .reset-page::before,
        .reset-page::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
        }

        .reset-page::before {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
            top: -100px;
            left: -100px;
        }

        .reset-page::after {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(120,100,180,0.06) 0%, transparent 70%);
            bottom: -80px;
            right: -80px;
        }

    .reset-card {
        width: 420px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 52px 44px 44px;
        position: relative;
        text-align: center;
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
        box-shadow: 0 0 0 1px rgba(201,169,110,0.05), 0 32px 64px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.04);
    }

        .reset-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 44px;
            right: 44px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .reset-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 24px;
        border: 1px solid rgba(201,169,110,0.25);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(201,169,110,0.06);
    }

        .reset-icon svg {
            width: 22px;
            height: 22px;
            stroke: var(--gold);
            fill: none;
            stroke-width: 1.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .reset-eyebrow {
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 400;
        margin-bottom: 10px;
    }

    .reset-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--text);
        line-height: 1;
        letter-spacing: -0.01em;
        margin-bottom: 10px;
    }

    .reset-subtitle {
        font-size: 13px;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 36px;
    }

    .field {
        margin-bottom: 16px;
        text-align: left;
    }

        .field label {
            display: block;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 8px;
            font-weight: 400;
        }

    .field-input-wrap {
        position: relative;
    }

    .field input {
        width: 100%;
        background: var(--input-bg);
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        font-weight: 300;
        padding: 13px 44px 13px 16px;
        outline: none;
        transition: border-color 0.25s, box-shadow 0.25s;
        -webkit-appearance: none;
    }

        .field input::placeholder {
            color: rgba(255,255,255,0.15);
        }

        .field input:focus {
            border-color: rgba(201,169,110,0.4);
            box-shadow: 0 0 0 3px rgba(201,169,110,0.06);
        }

    .toggle-pw {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        color: var(--muted);
        transition: color 0.2s;
    }

        .toggle-pw:hover {
            color: var(--gold);
        }

        .toggle-pw svg {
            width: 16px;
            height: 16px;
            stroke: currentColor;
            fill: none;
            stroke-width: 1.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* Strength meter */
    .strength-bar {
        display: flex;
        gap: 4px;
        margin-top: 10px;
    }

        .strength-bar span {
            flex: 1;
            height: 3px;
            border-radius: 2px;
            background: var(--border);
            transition: background 0.3s;
        }

    .strength-label {
        font-size: 11px;
        color: var(--muted);
        text-align: right;
        margin-top: 6px;
        min-height: 16px;
        transition: color 0.3s;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .btn-reset {
        width: 100%;
        margin-top: 24px;
        padding: 14px;
        background: linear-gradient(135deg, #b8934a, var(--gold-light), #b8934a);
        background-size: 200% 100%;
        background-position: right center;
        border: none;
        border-radius: 3px;
        color: #1a120a;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background-position 0.4s ease, box-shadow 0.3s;
        box-shadow: 0 4px 20px rgba(201,169,110,0.2);
    }

        .btn-reset:hover {
            background-position: left center;
            box-shadow: 0 6px 28px rgba(201,169,110,0.35);
        }

        .btn-reset:active {
            transform: translateY(1px);
            box-shadow: 0 2px 10px rgba(201,169,110,0.2);
        }

    .footer-note {
        text-align: center;
        margin-top: 28px;
        font-size: 13px;
        color: var(--muted);
        font-weight: 300;
    }

        .footer-note a {
            color: var(--gold);
            text-decoration: none;
            font-weight: 400;
            transition: color 0.2s;
        }

            .footer-note a:hover {
                color: var(--gold-light);
            }
</style>

<div class="reset-page">
    <div class="reset-card">

        <div class="reset-icon">
            <svg viewBox="0 0 24 24">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0110 0v4" />
            </svg>
        </div>

        <p class="reset-eyebrow">Account security</p>
        <h1 class="reset-title">Reset Password</h1>
        <p class="reset-subtitle">Choose a strong new password<br>to secure your account.</p>

        <form method="post">
            <div class="field">
                <label for="password">New Password</label>
                <div class="field-input-wrap">
                    <input id="password" name="password" type="password"
                           placeholder="Enter new password" required autocomplete="new-password"
                           oninput="checkStrength(this.value)" />
                    <button type="button" class="toggle-pw" onclick="togglePw()" aria-label="Toggle password">
                        <svg id="eyeIcon" viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
                <div class="strength-bar">
                    <span id="s1"></span>
                    <span id="s2"></span>
                    <span id="s3"></span>
                    <span id="s4"></span>
                </div>
                <p class="strength-label" id="strengthLabel"></p>
            </div>

            <button type="submit" class="btn-reset">Reset Password</button>
        </form>

        <p class="footer-note">
            Back to <a href="/Auth/Login">Sign in</a>
        </p>

    </div>
</div>

<script>
    function togglePw() {
        const input = document.getElementById('password');
        const icon  = document.getElementById('eyeIcon');
        const show  = input.type === 'password';
        input.type  = show ? 'text' : 'password';
        icon.innerHTML = show
            ? '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>'
            : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    }

    function checkStrength(val) {
        const bars   = [s1, s2, s3, s4];
        const label  = document.getElementById('strengthLabel');
        const colors = ['#e07070', '#e0a870', '#a8c870', '#7ec89a'];
        const labels = ['Weak', 'Fair', 'Good', 'Strong'];

        let score = 0;
        if (val.length >= 8)           score++;
        if (/[A-Z]/.test(val))         score++;
        if (/[0-9]/.test(val))         score++;
        if (/[^A-Za-z0-9]/.test(val))  score++;

        bars.forEach((b, i) => {
            b.style.background = i < score ? colors[score - 1] : 'rgba(255,255,255,0.07)';
        });

        label.textContent = val.length ? (labels[score - 1] || '') : '';
        label.style.color = val.length ? colors[score - 1] : '';
    }
</script>

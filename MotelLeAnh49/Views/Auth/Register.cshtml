@model MotelLeAnh49.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
@{
    ViewData["Title"] = "Register";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0d0d0f;
        --surface: #131317;
        --border: rgba(255,255,255,0.07);
        --gold: #c9a96e;
        --gold-light: #e8c98a;
        --text: #e8e4dc;
        --muted: #6b6763;
        --input-bg: #1a1a20;
        --danger: #e07070;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .register-page {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: var(--bg);
        font-family: 'DM Sans', sans-serif;
        position: relative;
        overflow: hidden;
        padding: 40px 16px;
    }

        .register-page::before,
        .register-page::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
        }

        .register-page::before {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
            top: -100px;
            right: -80px;
        }

        .register-page::after {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(120,100,180,0.06) 0%, transparent 70%);
            bottom: -80px;
            left: -80px;
        }

    .register-card {
        width: 460px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 52px 44px 44px;
        position: relative;
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
        box-shadow: 0 0 0 1px rgba(201,169,110,0.05), 0 32px 64px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.04);
    }

        .register-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 44px;
            right: 44px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Header */
    .register-header {
        margin-bottom: 36px;
    }

    .register-eyebrow {
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 400;
        margin-bottom: 10px;
    }

    .register-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        font-weight: 300;
        color: var(--text);
        line-height: 1;
        letter-spacing: -0.01em;
    }

    /* Section label */
    .section-label {
        font-size: 10px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 400;
        margin: 28px 0 18px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    /* Fields */
    .field {
        margin-bottom: 16px;
    }

        .field label {
            display: block;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 8px;
            font-weight: 400;
        }

        .field input {
            width: 100%;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 3px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 300;
            padding: 13px 16px;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
            -webkit-appearance: none;
        }

            .field input::placeholder {
                color: rgba(255,255,255,0.15);
            }

            .field input:focus {
                border-color: rgba(201,169,110,0.4);
                box-shadow: 0 0 0 3px rgba(201,169,110,0.06);
            }

    /* Two-column grid */
    .field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    /* Button */
    .btn-register {
        width: 100%;
        margin-top: 28px;
        padding: 14px;
        background: linear-gradient(135deg, #b8934a, var(--gold-light), #b8934a);
        background-size: 200% 100%;
        background-position: right center;
        border: none;
        border-radius: 3px;
        color: #1a120a;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background-position 0.4s ease, box-shadow 0.3s;
        box-shadow: 0 4px 20px rgba(201,169,110,0.2);
    }

        .btn-register:hover {
            background-position: left center;
            box-shadow: 0 6px 28px rgba(201,169,110,0.35);
        }

        .btn-register:active {
            transform: translateY(1px);
            box-shadow: 0 2px 10px rgba(201,169,110,0.2);
        }

    /* Footer */
    .footer-note {
        text-align: center;
        margin-top: 24px;
        font-size: 13px;
        color: var(--muted);
        font-weight: 300;
    }

        .footer-note a {
            color: var(--gold);
            text-decoration: none;
            font-weight: 400;
            transition: color 0.2s;
        }

            .footer-note a:hover {
                color: var(--gold-light);
            }
</style>

<div class="register-page">
    <div class="register-card">

        <div class="register-header">
            <p class="register-eyebrow">Get started</p>
            <h1 class="register-title">Create Account</h1>
        </div>

        @if (ViewBag.Error != null)
        {
            <div style="color:#e07070; margin-bottom:15px; font-size:14px;">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Register" method="post">

            <!-- Account Info -->
            <div class="field">
                <label asp-for="Username"></label>
                <input asp-for="Username" placeholder="Choose a username" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="text" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- Customer Info -->
            <p class="section-label">Personal Information</p>

            <div class="field">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" placeholder="Your full name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="field-row">

                <div class="field">
                    <label asp-for="Phone"></label>
                    <input asp-for="Phone" placeholder="0912345678" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="IdentityNumber"></label>
                    <input asp-for="IdentityNumber" placeholder="Identity number" />
                    <span asp-validation-for="IdentityNumber" class="text-danger"></span>
                </div>

            </div>

            <div class="field">
                <label asp-for="Address"></label>
                <input asp-for="Address" placeholder="Your address" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-register">Create Account</button>

        </form>

        <p class="footer-note">
            Already have an account? <a href="/Auth/Login">Sign in</a>
        </p>

    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
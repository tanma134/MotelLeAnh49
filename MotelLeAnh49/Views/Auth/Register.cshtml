@{
    ViewData["Title"] = "Register";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    .register-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .register-card {
        width: 420px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        animation: fadeUp .5s ease;
    }

</style>

<div class="container register-wrapper">

    <div class="card register-card p-4">

        <h3 class="text-center mb-4">Create Account</h3>

        <form method="post">

            <input name="Username" class="form-control mb-3" placeholder="Username" />

            <input name="Password" type="password" class="form-control mb-3" placeholder="Password" />

            <input name="Email" type="email" class="form-control mb-3" placeholder="Email" />

            <hr>

            <h5>Customer Information</h5>

            <input name="FullName" class="form-control mb-2" placeholder="Full Name" />

            <input name="Phone" class="form-control mb-2" placeholder="Phone" />

            <input name="Address" class="form-control mb-2" placeholder="Address" />

            <input name="IdentityNumber" class="form-control mb-3" placeholder="Identity Number" />

            <button class="btn btn-success w-100">
                Register
            </button>

        </form>

    </div>

</div>
@{
    ViewData["Title"] = "Verify OTP";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    .verify-wrapper {
        min-height: 70vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .verify-card {
        width: 400px;
        border-radius: 15px;
        animation: fadeIn .6s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>

<div class="container verify-wrapper">

    <div class="card verify-card shadow-lg p-4 text-center">

        <h3 class="mb-4">Email Verification</h3>

        <form method="post">

            <input name="otp"
                   class="form-control text-center mb-3"
                   placeholder="Enter OTP code" />

            <button class="btn btn-success w-100">
                Verify OTP
            </button>

        </form>

        @if (ViewBag.Error != null)
        {
            <p class="text-danger mt-3">@ViewBag.Error</p>
        }

        @if (ViewBag.Success != null)
        {
            <p class="text-success mt-3">@ViewBag.Success</p>
        }

        <hr />

        <p class="text-muted">
            Resend OTP in
            <span id="countdown">60</span> seconds
        </p>

        <button id="resendBtn"
                class="btn btn-warning w-100"
                disabled>
            Resend OTP
        </button>

    </div>

</div>

<script>

    let time = 60;

    let timer = setInterval(function(){

    time--;

    document.getElementById("countdown").innerText = time;

    if(time <= 0){

    clearInterval(timer);

    document.getElementById("resendBtn").disabled = false;

    document.getElementById("countdown").innerText = "0";

    }

    },1000);

</script>

<script>

    @if (ViewBag.Success != null)
    {
        <text>

        setTimeout(function(){

        window.location.href="/Auth/Login";

        },3000);

        </text>
    }

</script>
@{
    ViewData["Title"] = "Verify OTP";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0d0d0f;
        --surface: #131317;
        --border: rgba(255,255,255,0.07);
        --gold: #c9a96e;
        --gold-light: #e8c98a;
        --text: #e8e4dc;
        --muted: #6b6763;
        --input-bg: #1a1a20;
        --danger: #e07070;
        --success: #7ec89a;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .verify-page {
        min-height: 70vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: var(--bg);
        font-family: 'DM Sans', sans-serif;
        position: relative;
        overflow: hidden;
        padding: 40px 16px;
    }

        .verify-page::before,
        .verify-page::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
        }

        .verify-page::before {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
            top: -100px;
            left: -100px;
        }

        .verify-page::after {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(120,100,180,0.06) 0%, transparent 70%);
            bottom: -80px;
            right: -80px;
        }

    .verify-card {
        width: 420px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 52px 44px 44px;
        position: relative;
        text-align: center;
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
        box-shadow: 0 0 0 1px rgba(201,169,110,0.05), 0 32px 64px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.04);
    }

        .verify-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 44px;
            right: 44px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Icon */
    .verify-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 24px;
        border: 1px solid rgba(201,169,110,0.25);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(201,169,110,0.06);
    }

        .verify-icon svg {
            width: 24px;
            height: 24px;
            stroke: var(--gold);
            fill: none;
            stroke-width: 1.5;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* Header */
    .verify-eyebrow {
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 400;
        margin-bottom: 10px;
    }

    .verify-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 36px;
        font-weight: 300;
        color: var(--text);
        line-height: 1;
        letter-spacing: -0.01em;
        margin-bottom: 10px;
    }

    .verify-subtitle {
        font-size: 13px;
        color: var(--muted);
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 36px;
    }

    /* OTP Input */
    .field {
        margin-bottom: 16px;
    }

        .field input {
            width: 100%;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 3px;
            color: var(--text);
            font-family: 'Cormorant Garamond', serif;
            font-size: 28px;
            font-weight: 400;
            letter-spacing: 0.3em;
            text-align: center;
            padding: 16px;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
            -webkit-appearance: none;
        }

            .field input::placeholder {
                color: rgba(255,255,255,0.12);
                font-size: 16px;
                letter-spacing: 0.1em;
                font-family: 'DM Sans', sans-serif;
            }

            .field input:focus {
                border-color: rgba(201,169,110,0.4);
                box-shadow: 0 0 0 3px rgba(201,169,110,0.06);
            }

    /* Verify button */
    .btn-verify {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #b8934a, var(--gold-light), #b8934a);
        background-size: 200% 100%;
        background-position: right center;
        border: none;
        border-radius: 3px;
        color: #1a120a;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background-position 0.4s ease, box-shadow 0.3s;
        box-shadow: 0 4px 20px rgba(201,169,110,0.2);
    }

        .btn-verify:hover {
            background-position: left center;
            box-shadow: 0 6px 28px rgba(201,169,110,0.35);
        }

        .btn-verify:active {
            transform: translateY(1px);
        }

    /* Messages */
    .msg-error,
    .msg-success {
        font-size: 13px;
        text-align: center;
        margin-top: 16px;
        font-weight: 300;
    }

    .msg-error {
        color: var(--danger);
    }

    .msg-success {
        color: var(--success);
    }

    /* Divider */
    .divider {
        height: 1px;
        background: var(--border);
        margin: 28px 0;
    }

    /* Countdown */
    .countdown-text {
        font-size: 13px;
        color: var(--muted);
        font-weight: 300;
        margin-bottom: 14px;
    }

        .countdown-text span {
            font-family: 'Cormorant Garamond', serif;
            font-size: 18px;
            font-weight: 400;
            color: var(--gold);
            display: inline-block;
            min-width: 24px;
        }

    /* Resend button */
    .btn-resend {
        width: 100%;
        padding: 12px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--muted);
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 400;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: border-color 0.3s, color 0.3s, box-shadow 0.3s;
    }

        .btn-resend:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

        .btn-resend:not(:disabled):hover {
            border-color: rgba(201,169,110,0.35);
            color: var(--gold-light);
            box-shadow: 0 0 0 3px rgba(201,169,110,0.05);
        }
</style>

<div class="verify-page">
    <div class="verify-card">

        <div class="verify-icon">
            <svg viewBox="0 0 24 24">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
        </div>

        <p class="verify-eyebrow">Security check</p>
        <h1 class="verify-title">Verify Email</h1>
        <p class="verify-subtitle">We sent a one-time code to your email address.<br>Enter it below to continue.</p>

        <form method="post">
            <div class="field">
                <input name="otp" type="text" placeholder="Enter OTP code" maxlength="6" inputmode="numeric" autocomplete="one-time-code" />
            </div>
            <button type="submit" class="btn-verify">Verify Code</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <p class="msg-error">@ViewBag.Error</p>
        }
        @if (ViewBag.Success != null)
        {
            <p class="msg-success">@ViewBag.Success</p>
        }

        <div class="divider"></div>

        <p class="countdown-text">
            Resend code in <span id="countdown">60</span>s
        </p>

        <button id="resendBtn" class="btn-resend" disabled>
            Resend OTP
        </button>

    </div>
</div>

<script>
    let time = 60;
    const timer = setInterval(function () {
        time--;
        document.getElementById("countdown").innerText = time;
        if (time <= 0) {
            clearInterval(timer);
            document.getElementById("resendBtn").disabled = false;
            document.getElementById("countdown").innerText = "0";
        }
    }, 1000);
</script>

<script>
    @if (ViewBag.Success != null)
    {
        <text>
            setTimeout(function () {
                window.location.href = "/Auth/Login";
            }, 3000);
        </text>
    }
</script>

@{
    ViewData["Title"] = "Login";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --bg: #0d0d0f;
        --surface: #131317;
        --border: rgba(255,255,255,0.07);
        --gold: #c9a96e;
        --gold-light: #e8c98a;
        --text: #e8e4dc;
        --muted: #6b6763;
        --input-bg: #1a1a20;
        --danger: #e07070;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .login-page {
        min-height: calc(100vh - 70px);
        padding: 120px 0;
        display: flex;
        justify-content: center;
        align-items: center;
        background: var(--bg);
        font-family: 'DM Sans', sans-serif;
        position: relative;
        overflow: hidden;
    }

        /* Ambient background orbs */
        .login-page::before,
        .login-page::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
        }

        .login-page::before {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(201,169,110,0.08) 0%, transparent 70%);
            top: -100px;
            left: -100px;
        }

        .login-page::after {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(120,100,180,0.06) 0%, transparent 70%);
            bottom: -80px;
            right: -80px;
        }

    .login-card {
        width: 420px;
        margin: 40px 0;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 52px 44px 44px;
        position: relative;
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
        box-shadow: 0 0 0 1px rgba(201,169,110,0.05), 0 32px 64px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.04);
    }

        /* Top gold accent line */
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 44px;
            right: 44px;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(28px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Header */
    .login-header {
        margin-bottom: 40px;
    }

    .login-eyebrow {
        font-size: 10px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        font-weight: 400;
        font-family: 'DM Sans', sans-serif;
        margin-bottom: 10px;
    }

    .login-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        font-weight: 300;
        color: var(--text);
        line-height: 1;
        letter-spacing: -0.01em;
    }

    /* Form fields */
    .field {
        margin-bottom: 22px;
    }

        .field label {
            display: block;
            font-size: 11px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 10px;
            font-weight: 400;
        }

        .field input {
            width: 100%;
            background: var(--input-bg);
            border: 1px solid var(--border);
            border-radius: 3px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            font-weight: 300;
            padding: 13px 16px;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
            -webkit-appearance: none;
        }

            .field input::placeholder {
                color: rgba(255,255,255,0.15);
            }

            .field input:focus {
                border-color: rgba(201,169,110,0.4);
                box-shadow: 0 0 0 3px rgba(201,169,110,0.06);
            }

    /* Submit button */
    .btn-login {
        width: 100%;
        margin-top: 8px;
        padding: 14px;
        background: linear-gradient(135deg, #b8934a, var(--gold-light), #b8934a);
        background-size: 200% 100%;
        background-position: right center;
        border: none;
        border-radius: 3px;
        color: #1a120a;
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background-position 0.4s ease, box-shadow 0.3s;
        box-shadow: 0 4px 20px rgba(201,169,110,0.2);
    }

        .btn-login:hover {
            background-position: left center;
            box-shadow: 0 6px 28px rgba(201,169,110,0.35);
        }

        .btn-login:active {
            transform: translateY(1px);
            box-shadow: 0 2px 10px rgba(201,169,110,0.2);
        }

    /* Error */
    .error-msg {
        font-size: 13px;
        color: var(--danger);
        text-align: center;
        margin-top: 16px;
        min-height: 20px;
        opacity: 0.9;
    }

    /* Divider */
    .divider {
        display: flex;
        align-items: center;
        gap: 14px;
        margin: 32px 0 24px;
    }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .divider span {
            font-size: 10px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--muted);
        }

    /* Footer links */
    .footer-links {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .footer-links a {
            font-size: 13px;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s;
            font-weight: 300;
        }

            .footer-links a:hover {
                color: var(--gold-light);
            }

            .footer-links a.primary {
                color: var(--gold);
                font-weight: 400;
            }

                .footer-links a.primary:hover {
                    color: var(--gold-light);
                }
</style>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <p class="login-eyebrow">Welcome back</p>
            <h1 class="login-title">Sign In</h1>
        </div>

        <form method="post">
            <div class="field">
                <label for="username">Username</label>
                <input id="username" name="username" type="text" placeholder="Enter your username" autocomplete="username" />
            </div>

            <div class="field">
                <label for="password">Password</label>
                <input id="password" name="password" type="password" placeholder="••••••••" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn-login">Continue</button>

            <p class="error-msg">@ViewBag.Error</p>
        </form>

        <div class="divider"><span>or</span></div>

        <div class="footer-links">
            <a href="/Auth/Register" class="primary">Create account</a>
            <a href="/Auth/ForgotPassword">Forgot password?</a>
        </div>
    </div>
</div>

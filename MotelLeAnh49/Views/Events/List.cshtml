@model IEnumerable<MotelLeAnh49.Models.Event>

@{
    ViewData["Title"] = "Danh sách sự kiện";
}

<div class="container py-4">
    <h2 class="mb-4">📅 Sự kiện tại Motel Lê Anh 49</h2>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var ev in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@ev.Title</h5>
                            <p class="card-text text-muted">
                                <i class="fas fa-map-marker-alt me-1"></i>@ev.Location, @ev.City
                            </p>
                            <p class="card-text">
                                <i class="far fa-calendar-alt me-1"></i>@ev.EventDate.ToString("dd/MM/yyyy HH:mm")
                            </p>
                            <p class="card-text">
                                @(ev.Description?.Length > 80 ? ev.Description.Substring(0, 80) + "..." : ev.Description)
                            </p>
                            <div class="mt-auto">
                                <a asp-action="Details"
                                   asp-route-id="@ev.EventId"
                                   class="btn btn-primary w-100">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Hiện chưa có sự kiện nào.
        </div>
    }
</div>


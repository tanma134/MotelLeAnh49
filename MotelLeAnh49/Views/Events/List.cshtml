@model IEnumerable<MotelLeAnh49.Models.Event>

<div class="container py-5">
    <h2 class="text-center mb-5">🎉 Sự kiện tại Motel Lê Anh 49</h2>

    <div class="row">
        @foreach (var ev in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card event-card shadow-sm">

                    <img src="@ev.ImageUrl"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold">
                            @ev.Title
                        </h5>

                        <p class="text-muted mb-1">
                            <i class="fas fa-map-marker-alt"></i>
                            @ev.Location, @ev.City
                        </p>

                        <p class="text-muted mb-2">
                            <i class="far fa-calendar-alt"></i>
                            @ev.EventDate.ToString("dd/MM/yyyy HH:mm")
                        </p>

                        <p>
                            @(ev.Description.Length > 70
                                ? ev.Description.Substring(0, 70) + "..."
                                : ev.Description)
                        </p>

                        <div class="mt-auto">

                            <a asp-action="Details"
                               asp-route-id="@ev.EventId"
                               class="btn btn-primary w-100">
                                Xem chi tiết
                            </a>

                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>
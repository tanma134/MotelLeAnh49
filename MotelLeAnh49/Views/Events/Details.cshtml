@model MotelLeAnh49.Models.Event

@{
    ViewData["Title"] = "Chi tiết sự kiện";
}

<div class="container py-4">
    <a asp-action="List" class="btn btn-link mb-3">&laquo; Quay lại danh sách sự kiện</a>

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="card-title mb-3">@Model.Title</h2>

            <p class="text-muted mb-2">
                <i class="fas fa-map-marker-alt me-1"></i>@Model.Location, @Model.City
            </p>
            <p class="text-muted mb-3">
                <i class="far fa-calendar-alt me-1"></i>@Model.EventDate.ToString("dd/MM/yyyy HH:mm")
            </p>

            <p class="mb-4">
                @Model.Description
            </p>

            <a asp-action="Join"
               asp-route-id="@Model.EventId"
               class="btn btn-primary">
                Tham gia sự kiện
            </a>
        </div>
    </div>
</div>


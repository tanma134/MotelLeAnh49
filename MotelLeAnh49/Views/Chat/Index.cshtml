@* MotelLeAnh49/Views/Chat/Index.cshtml *@
@{
    ViewData["Title"] = "Concierge IA";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
          --bg:#0e0d0b; --surface:#1a1915; --surface2:#242318; --surface3:#2e2d27;
          --gold:#c9a84c; --gold2:#e8c97a; --cream:#f0ead8; --muted:#8a8674;
          --border:#3a3930; --radius:14px;
          --user-bg:#2a2615; --user-border:#c9a84c;
          --ai-bg:#1e1e1a; --ai-border:#3a3930;
        }
        body { background: var(--bg); }

        .chat-shell {
          display: flex; flex-direction: column;
          height: 620px; max-width: 720px; margin: 32px auto;
          border: 0.5px solid var(--border); border-radius: var(--radius);
          overflow: hidden; background: var(--surface);
          font-family: 'DM Mono', monospace;
        }

        .chat-header {
          padding: 16px 20px 14px; border-bottom: 0.5px solid var(--border);
          display: flex; align-items: center; gap: 12px; background: var(--surface2);
        }
        .hotel-icon {
          width: 36px; height: 36px; border-radius: 50%; background: var(--gold);
          display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0;
        }
        .header-title { font-family: 'DM Serif Display', serif; font-size: 16px; color: var(--cream); }
        .header-sub   { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; margin-top: 2px; }
        .status-dot   { width: 7px; height: 7px; border-radius: 50%; background: #4caf7d; margin-left: auto; flex-shrink: 0; }

        .messages {
          flex: 1; overflow-y: auto; padding: 16px;
          display: flex; flex-direction: column; gap: 12px;
          scrollbar-width: thin; scrollbar-color: var(--border) transparent;
        }
        .msg { display: flex; flex-direction: column; max-width: 82%; }
        .msg.user { align-self: flex-end; align-items: flex-end; }
        .msg.ai   { align-self: flex-start; }
        .msg-label {
          font-size: 10px; letter-spacing: .06em; text-transform: uppercase;
          color: var(--muted); margin-bottom: 4px;
        }
        .msg.user .msg-label { color: #a07a2a; }
        .bubble {
          padding: 10px 14px; border-radius: var(--radius);
          font-size: 13px; line-height: 1.6; white-space: pre-wrap; word-break: break-word;
        }
        .msg.user .bubble {
          background: var(--user-bg); border: 0.5px solid var(--user-border);
          color: var(--cream); border-bottom-right-radius: 4px;
        }
        .msg.ai .bubble {
          background: var(--ai-bg); border: 0.5px solid var(--ai-border);
          color: #ccc8b8; border-bottom-left-radius: 4px;
        }

        .typing { display: flex; gap: 5px; padding: 12px 14px; align-items: center; }
        .typing span {
          width: 5px; height: 5px; border-radius: 50%; background: var(--gold);
          animation: blink 1.2s ease-in-out infinite;
        }
        .typing span:nth-child(2) { animation-delay: .2s; }
        .typing span:nth-child(3) { animation-delay: .4s; }
        @@keyframes blink { 0%,80%,100%{opacity:.2} 40%{opacity:1} }

        .log-strip {
          font-size: 10px; color: var(--muted); text-align: center;
          padding: 4px 12px; opacity: .7; letter-spacing: .03em;
        }

        .composer {
          border-top: 0.5px solid var(--border); padding: 14px 16px;
          display: flex; align-items: flex-end; gap: 10px; background: var(--surface2);
        }
        .composer textarea {
          flex: 1; background: var(--surface3); border: 0.5px solid var(--border);
          border-radius: 10px; padding: 10px 12px; font-family: 'DM Mono', monospace;
          font-size: 13px; color: var(--cream); resize: none; outline: none;
          min-height: 40px; max-height: 120px; line-height: 1.5; transition: border-color .2s;
        }
        .composer textarea::placeholder { color: var(--muted); }
        .composer textarea:focus { border-color: var(--gold); }
        .send-btn {
          width: 38px; height: 38px; border-radius: 50%; background: var(--gold);
          border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
          flex-shrink: 0; transition: background .15s, transform .1s;
        }
        .send-btn:hover  { background: var(--gold2); }
        .send-btn:active { transform: scale(.95); }
        .send-btn:disabled { opacity: .5; cursor: not-allowed; }
        .send-btn svg {
          width: 16px; height: 16px; fill: none; stroke: #0e0d0b;
          stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
        }
    </style>
}

<div class="chat-shell">

    <div class="chat-header">
        <div class="hotel-icon">&#9768;</div>
        <div>
            <div class="header-title">Concierge IA — MotelLeAnh49</div>
            <div class="header-sub">Always on duty · Ask me anything</div>
        </div>
        <div class="status-dot"></div>
    </div>

    <div class="messages" id="messages">
        <div class="msg ai">
            <div class="msg-label">Concierge IA</div>
            <div class="bubble">Xin chào! Tôi là trợ lý ảo của MotelLeAnh49. Tôi có thể giúp gì cho bạn?</div>
        </div>
    </div>

    <div class="log-strip" id="log">Ready</div>

    <div class="composer">
        @Html.AntiForgeryToken()
        <textarea id="input" rows="1" placeholder="Hỏi về phòng, giá, đặt phòng…"></textarea>
        <button class="send-btn" id="sendBtn" type="button">
            <svg viewBox="0 0 24 24">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
        </button>
    </div>

</div>

@section Scripts {
    <script>
        const messagesEl = document.getElementById('messages');
        const inputEl    = document.getElementById('input');
        const logEl      = document.getElementById('log');
        const sendBtn    = document.getElementById('sendBtn');
        const token      = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        function setLog(text) { logEl.textContent = text; }

        function addMessage(role, text) {
          const wrapper = document.createElement('div');
          wrapper.className = 'msg ' + role;
          const label = document.createElement('div');
          label.className = 'msg-label';
          label.textContent = role === 'user' ? 'Bạn' : 'Concierge IA';
          const bubble = document.createElement('div');
          bubble.className = 'bubble';
          bubble.textContent = text;
          wrapper.appendChild(label);
          wrapper.appendChild(bubble);
          messagesEl.appendChild(wrapper);
          messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function showTyping() {
          const wrapper = document.createElement('div');
          wrapper.className = 'msg ai';
          wrapper.id = 'typing-indicator';
          const label = document.createElement('div');
          label.className = 'msg-label';
          label.textContent = 'Concierge IA';
          const bubble = document.createElement('div');
          bubble.className = 'bubble typing';
          bubble.innerHTML = '<span></span><span></span><span></span>';
          wrapper.appendChild(label);
          wrapper.appendChild(bubble);
          messagesEl.appendChild(wrapper);
          messagesEl.scrollTop = messagesEl.scrollHeight;
        }

        function hideTyping() {
          const el = document.getElementById('typing-indicator');
          if (el) el.remove();
        }

        inputEl.addEventListener('input', () => {
          inputEl.style.height = 'auto';
          inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
        });

        inputEl.addEventListener('keydown', e => {
          if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend(); }
        });

        sendBtn.addEventListener('click', handleSend);

        async function handleSend() {
          const text = inputEl.value.trim();
          if (!text) return;

          inputEl.value = '';
          inputEl.style.height = 'auto';
          sendBtn.disabled = true;
          inputEl.disabled = true;

          addMessage('user', text);
          setLog('Đang xử lý…');
          showTyping();

          try {
            const res = await fetch('/Chat/Send', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
              },
              body: JSON.stringify({ message: text })
            });

            if (!res.ok) throw new Error('Lỗi server: ' + res.status);

            const data = await res.json();
            hideTyping();
            addMessage('ai', data.response);
            setLog('Đã lưu · ' + new Date().toLocaleTimeString());

          } catch (err) {
            hideTyping();
            addMessage('ai', 'Xin lỗi — đã xảy ra lỗi kết nối. Vui lòng thử lại.');
            setLog('Lỗi: ' + err.message);
          }

          sendBtn.disabled = false;
          inputEl.disabled = false;
          inputEl.focus();
        }
    </script>
}

@model List<MotelLeAnh49.Models.Booking>

@{
    ViewData["Title"] = "Lịch sử đặt phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <div class="card shadow border-0">

        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">
                <i class="fas fa-history"></i> Lịch sử đặt phòng
            </h4>
        </div>

        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    Bạn chưa có lịch sử đặt phòng.
                </div>
            }
            else
            {

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-dark">
                            <tr>
                                <th>Phòng</th>
                                <th>Check In</th>
                                <th>Check Out</th>
                                <th>Người lớn</th>
                                <th>Trẻ em</th>
                                <th>Trạng thái</th>
                                <th width="120">Action</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var booking in Model)
                            {

                                <tr>

                                    <td>
                                        <strong>Phòng @booking.Room?.RoomNumber</strong>
                                    </td>

                                    <td>
                                        @booking.CheckIn.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        @booking.CheckOut.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>@booking.Adults</td>

                                    <td>@booking.Children</td>

                                    <td>

                                        @if (booking.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Chờ duyệt
                                            </span>
                                        }
                                        else if (booking.Status == "Confirmed")
                                        {
                                            <span class="badge bg-success">
                                                Đã xác nhận
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Đã hủy
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if ((booking.Status == "Pending" || booking.Status == "Confirmed")
                                                                        && booking.CheckIn > DateTime.Today)
                                        {

                                            <a asp-controller="Bookings"
                                               asp-action="Cancel"
                                               asp-route-id="@booking.Id"
                                               class="btn btn-danger btn-sm"
                                               onclick="return confirm('Bạn chắc chắn muốn hủy?')">

                                                <i class="fas fa-times"></i> Hủy
                                            </a>

                                        }

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                </div>

            }

        </div>

    </div>

</div>
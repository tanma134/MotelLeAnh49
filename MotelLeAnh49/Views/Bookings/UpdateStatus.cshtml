@model MotelLeAnh49.Models.Booking
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    bool isCancelled = Model.Status == "Cancelled";
    bool isCompleted = Model.CheckOut < DateTime.Now;
    bool isLocked = isCancelled || isCompleted;
}

<div asp-validation-summary="All" style="color:red"></div>

<div class="form-container">
    <h2>✏️ Update Booking</h2>

    @if (isCancelled)
    {
        <div class="alert cancelled">⚠️ Booking đã bị hủy - Không thể chỉnh sửa</div>
    }
    else if (isCompleted)
    {
        <div class="alert completed">✅ Booking đã hoàn thành - Chỉ xem</div>
    }

    <form asp-action="UpdateStatus" method="post" id="bookingForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="CustomerId" />

        <!-- CUSTOMER -->
        <div class="form-group">
            <label>Customer Name</label>
            <input asp-for="FullName" id="fullName" readonly="@isLocked" />
            <span id="err-fullName" class="error-msg"></span>
        </div>

        <div class="form-group">
            <label>Phone</label>
            <input asp-for="Phone" id="phone" type="tel" readonly="@isLocked" />
            <span id="err-phone" class="error-msg"></span>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" id="email" type="email" readonly="@isLocked" />
            <span id="err-email" class="error-msg"></span>
        </div>
        <div class="form-group">
            <label>Room</label>

            @if (isLocked)
            {
                <select asp-for="RoomId" asp-items="ViewBag.RoomList" disabled></select>
                <input type="hidden" asp-for="RoomId" />
            }
            else
            {
                    <select asp-for="RoomId" id="roomId" asp-items="ViewBag.RoomList"></select>
                    <input type="hidden" asp-for="RoomId" id="roomIdHidden" />
                }
        </div>
        <!-- DATES -->
        <div class="row">
            <div class="form-group">
                <label>Check In</label>
                <input asp-for="CheckIn" type="date" id="checkIn" readonly="@isLocked" />
                <span id="err-checkIn" class="error-msg"></span>
            </div>
            <div class="form-group">
                <label>Check Out</label>
                <input asp-for="CheckOut" type="date" id="checkOut" readonly="@isLocked" />
                <span id="err-checkOut" class="error-msg"></span>
            </div>
        </div>

        <!-- GUESTS -->
        <div class="row">
            <div class="form-group">
                <label>Adults</label>
                <input asp-for="Adults" id="adults" type="number" min="1" readonly="@isLocked" />
            </div>
            <div class="form-group">
                <label>Children</label>
                <input asp-for="Children" id="children" type="number" min="0" readonly="@isLocked" />
            </div>
        </div>

        <!-- THÔNG BÁO SỐ NGƯỜI -->
        <div id="extraFeeBox" class="extra-fee"></div>

        <!-- STATUS -->
        <div class="form-group">
            <label>Status</label>
            @if (isLocked)
            {
                <select asp-for="Status" disabled>
                    <option value="Pending">Pending</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
                <input type="hidden" asp-for="Status" />
            }
            else
            {
                <select asp-for="Status">
                    <option value="Pending">Pending</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            }
        </div>

        <div class="button-group">
            @if (!isLocked)
            {
                <button type="submit" id="btnSubmit" class="btn-save">💾 Save Changes</button>
            }
            <a asp-action="Index" class="btn-back">⬅ Back to List</a>
        </div>
    </form>
</div>

<style>
    .form-container {
        max-width: 700px;
        margin: 30px auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
    }

    input, select {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #ecf0f1;
        border-radius: 8px;
        font-size: 16px;
    }

        input:focus, select:focus {
            border-color: #3498db;
            box-shadow: 0 0 8px rgba(52,152,219,0.3);
        }

    .row {
        display: flex;
        gap: 15px;
    }

        .row .form-group {
            flex: 1;
        }

    .error-msg {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        min-height: 20px;
    }

    /* === EXTRA FEE BOX - QUAN TRỌNG === */
    .extra-fee {
        margin: 15px 0;
        padding: 14px;
        border-radius: 8px;
        font-weight: 600;
        min-height: 52px;
    }

    .button-group {
        display: flex;
        gap: 12px;
        margin-top: 30px;
    }

    .btn-save {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, #3498db, #2980b9);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
    }

        .btn-save:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: #6c757d;
        color: white;
        text-align: center;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
    }

    .alert {
        padding: 12px;
        margin-bottom: 20px;
        border-radius: 8px;
        text-align: center;
        font-weight: 600;
    }

    .cancelled {
        background: #ffe0e0;
        color: #c82333;
    }

    .completed {
        background: #d4edda;
        color: #155724;
    }
</style>

@section Scripts {
    <script src="~/js/booking-update.js"></script>
}
@model MotelLeAnh49.Models.Booking
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>

    body {
        font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
        background: #f5f7fa;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        font-size: 28px;
        text-align: center;
        border-bottom: 3px solid #f39c12;
        padding-bottom: 10px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        margin-bottom: 8px;
        color: #555;
        font-weight: 600;
        font-size: 14px;
    }

    input, select {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 15px;
        transition: all .3s ease;
    }

        input:focus, select:focus {
            outline: none;
            border-color: #f39c12;
            box-shadow: 0 0 0 3px rgba(243,156,18,.1);
        }

    .button-group {
        margin-top: 30px;
        display: flex;
        gap: 10px;
    }

    button {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg,#f39c12 0%,#e67e22 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: .3s;
    }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(243,156,18,.4);
        }

    .btn-back {
        flex: 1;
        padding: 14px;
        background: #95a5a6;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        text-align: center;
    }

        .btn-back:hover {
            background: #7f8c8d;
        }

</style>


<div class="form-container">

    <h2>✏️ Update Booking</h2>

    <form asp-action="UpdateStatus"
          asp-route-id="@Model.Id"
          method="post">

        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label>Customer Name</label>
            <input asp-for="FullName" />
        </div>

        <div class="form-group">
            <label>Phone</label>
            <input asp-for="Phone" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" />
        </div>

        <div class="form-group">
            <label>Room</label>

            <select asp-for="RoomId"
                    asp-items="ViewBag.RoomList">
            </select>

        </div>

        <div class="form-group">
            <label>Status</label>

            <select asp-for="Status">

                <option value="Pending">Pending</option>
                <option value="Confirmed">Confirmed</option>
                <option value="Cancelled">Cancelled</option>

            </select>

        </div>

        <div class="form-group">
            <label>Check In</label>

            <input asp-for="CheckIn"
                   type="date" />

        </div>

        <div class="form-group">
            <label>Check Out</label>

            <input asp-for="CheckOut"
                   type="date" />

        </div>

        <div class="button-group">

            <button type="submit">
                ✅ Update
            </button>

            <a asp-action="Index"
               class="btn-back">
                ⬅ Back
            </a>

        </div>

    </form>

</div>
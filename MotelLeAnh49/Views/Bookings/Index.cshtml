@model IEnumerable<MotelLeAnh49.Models.Booking>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        font-family: 'Segoe UI';
        background: #f5f7fa;
    }

    h2 {
        color: #2c3e50;
        border-bottom: 3px solid #3498db;
        padding-bottom: 10px;
        display: inline-block;
        margin-bottom: 20px;
    }

    .btn-add {
        background: linear-gradient(135deg,#667eea,#764ba2);
        color: white;
        padding: 10px 18px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    thead {
        background: linear-gradient(135deg,#667eea,#764ba2);
        color: white;
    }

    th, td {
        padding: 12px;
        text-align: center;
    }

    tbody tr:nth-child(even) {
        background: #fafbfc;
    }

    tbody tr:hover {
        background: #f0f2f5;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 13px;
        color: white;
    }

    .pending {
        background: #f39c12;
    }

    .confirmed {
        background: #27ae60;
    }

    .cancelled {
        background: #e74c3c;
    }

    .action-link {
        color: #3498db;
        text-decoration: none;
        padding: 5px 10px;
        border-radius: 4px;
    }

        .action-link:hover {
            background: #3498db;
            color: white;
        }
</style>

<div class="container">

    <h2>📋 Booking List</h2>

    <p>
        <a asp-action="Create" class="btn-add">➕ Create Booking</a>
    </p>

    <table>

        <thead>
            <tr>
                <th>Customer</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Room</th>
                <th>CheckIn</th>
                <th>CheckOut</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var b in Model)
            {
                <tr>
                    <td>@b.FullName</td>
                    <td>@b.Phone</td>
                    <td>@b.Email</td>
                    <td>Room @b.Room?.RoomNumber</td>
                    <td>@b.CheckIn.ToString("dd/MM/yyyy")</td>
                    <td>@b.CheckOut.ToString("dd/MM/yyyy")</td>

                    <td>

                        @if (b.Status=="Pending")
                        {
                            <span class="badge pending">Pending</span>
                        }
                        else if (b.Status=="Confirmed")
                        {
                            <span class="badge confirmed">Confirmed</span>
                        }
                        else
                        {
                            <span class="badge cancelled">Cancelled</span>
                        }

                    </td>

                    <td>
                        <a asp-action="UpdateStatus"
                           asp-route-id="@b.Id"
                           class="action-link">✏️ Edit</a>
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
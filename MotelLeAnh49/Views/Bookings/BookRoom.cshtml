@model MotelLeAnh49.Models.Booking

@{
    ViewData["Title"] = "Đặt phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">
                <i class="fas fa-calendar-check"></i> Đặt phòng
            </h4>
        </div>
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <form asp-action="BookRoom" method="post" id="bookingForm">
                <input type="hidden" asp-for="RoomId" value="@ViewBag.RoomId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" id="fullname" />
                        <small class="text-danger" id="nameError"></small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" id="phone" />
                        <small class="text-danger" id="phoneError"></small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" id="email" />
                        <small class="text-danger" id="emailError"></small>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Adults" class="form-label"></label>
                        <input asp-for="Adults" type="number" class="form-control" min="1" value="2" />
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Children" class="form-label"></label>
                        <input asp-for="Children" type="number" class="form-control" min="0" value="0" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CheckIn" class="form-label"></label>
                        <input asp-for="CheckIn" type="date" class="form-control" id="checkin" />
                        <small class="text-danger" id="checkinError"></small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CheckOut" class="form-label"></label>
                        <input asp-for="CheckOut" type="date" class="form-control" id="checkout" />
                        <small class="text-danger" id="checkoutError"></small>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100 mt-3" id="submitBtn" disabled>
                    <i class="fas fa-check-circle"></i> Xác nhận đặt phòng
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    #submitBtn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

@section Scripts {
    <script src="~/js/booking-form-validation.js"></script>
}
@model MotelLeAnh49.Models.Booking
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>

    .form-box {
        background: white;
        padding: 30px;
        max-width: 700px;
        margin: auto;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        border-radius: 8px;
    }

    input, select {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        margin-bottom: 15px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    button {
        background: #27ae60;
        border: none;
        padding: 10px 20px;
        color: white;
        border-radius: 6px;
        cursor: pointer;
    }

        button:hover {
            background: #1e8449;
        }

</style>

<div class="form-box">

    <h2>Create Booking</h2>

    <form asp-action="Create" method="post">

        <label>Customer Name</label>
        <input asp-for="FullName" />

        <label>Phone</label>
        <input asp-for="Phone" />

        <label>Email</label>
        <input asp-for="Email" />

        <label>Room</label>
        <select asp-for="RoomId" asp-items="ViewBag.RoomList"></select>

        <label>CheckIn</label>
        <input asp-for="CheckIn" type="date" />

        <label>CheckOut</label>
        <input asp-for="CheckOut" type="date" />

        <label>Adults</label>
        <input asp-for="Adults" />

        <label>Children</label>
        <input asp-for="Children" />

        <button>Create Booking</button>

    </form>

</div>